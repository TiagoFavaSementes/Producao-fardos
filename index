/* ---------- Dashboard: filtro de período (item 1) ---------- */
let dashDe = "", dashAte = "";   // ISO yyyy-mm-dd; ambos vazios = toda a safra
function isoLocal(d){ return d.getFullYear()+"-"+String(d.getMonth()+1).padStart(2,"0")+"-"+String(d.getDate()).padStart(2,"0"); }
// "DIA DE PRODUÇÃO": começa às 06:00 e vai até 05:59:59 do dia seguinte. A madrugada (00:00–05:59)
// conta no dia que COMEÇOU. (Constante — mude aqui se o corte do turno for outro horário.)
const CORTE_DIA_MIN = 6*60;   // 06:00
function diaProducaoDe(l){
  if(!l.dataReal) return l.data || "";                       // sem data real: l.data já é o dia de produção
  const min = timeToMin(l.horaInicio);
  if(min===null) return l.dataReal;
  return min >= CORTE_DIA_MIN ? l.dataReal : addDias(l.dataReal, -1);   // 00:00–05:59 → dia anterior
}
function diaProducaoAgora(){
  const d = new Date(); const min = d.getHours()*60 + d.getMinutes(); const hoje = isoLocal(d);
  return min >= CORTE_DIA_MIN ? hoje : addDias(hoje, -1);
}
function dentroPeriodo(l){
  const dp = diaProducaoDe(l);
  if(dashDe && (!dp || dp < dashDe)) return false;
  if(dashAte && (!dp || dp > dashAte)) return false;
  return true;
}
function lancamentosNoPeriodo(){ return state.lancamentos.filter(dentroPeriodo); }
// Texto do intervalo REAL (com horário) que o filtro está puxando — fica visível pro usuário.
function janelaPeriodoTxt(){
  if(!dashDe && !dashAte) return "Toda a safra";
  const ini = dashDe ? (fmtDateBR(dashDe)+" 06:00:00") : "início";
  const fim = dashAte ? (fmtDateBR(addDias(dashAte,1))+" 05:59:59") : "agora";
  return "Dia de produção · " + ini + "  →  " + fim;
}
function setPeriodo(tipo){
  if(tipo==="safra"){ dashDe=""; dashAte=""; }
  else if(tipo==="hoje"){ const h=diaProducaoAgora(); dashDe=h; dashAte=h; }
  else if(tipo==="ontem"){ const o=addDias(diaProducaoAgora(),-1); dashDe=o; dashAte=o; }
  const de=document.getElementById("dashDe"), ate=document.getElementById("dashAte");
  if(de) de.value=dashDe; if(ate) ate.value=dashAte;
  renderDash();
}

// F27 - gráfico de produção por HORA do dia (soma do PERÍODO), pelo horário de início da janela.
function renderChartPorHora(){
  const el = document.getElementById("chartHora"); if(!el) return;
  const buckets = new Map();   // hora(0-23) -> {a,b,real,horas}
  for(const l of lancamentosNoPeriodo()){
    if(!l.horaInicio) continue;
    const real = calcRealizado(l.fardoInicio, l.fardoFinal); if(real===null) continue;
    const h = parseInt(String(l.horaInicio).split(":")[0],10); if(isNaN(h)) continue;
    if(!buckets.has(h)) buckets.set(h,{a:0,b:0,real:0,horas:0});
    const g = buckets.get(h);
    if(l.turno==="A") g.a+=real; else g.b+=real;
    g.real+=real;
    const hh = calcHoras(l.horaInicio,l.horaFim); if(hh!==null) g.horas+=hh;
  }
  const arr = [...buckets.entries()].map(([h,g])=>({h,a:g.a,b:g.b,real:g.real,horas:g.horas})).sort((x,y)=>x.h-y.h);
  if(arr.length===0){ el.innerHTML = `<div class="empty">Sem lançamentos com horário ainda.</div>`; return; }
  const max = Math.max.apply(null, arr.map(x=>x.real).concat([1]));
  const meta = state.config.metaPorHora;
  el.innerHTML = arr.map(x=>{
    const wA = (x.a/max*100).toFixed(2), wB = (x.b/max*100).toFixed(2);
    const med = x.horas>0 ? x.real/x.horas : 0;
    const cor = med>=meta ? "#1b5e20" : "#8a6d00";
    return `<div class="bar-row">
      <div class="name">${String(x.h).padStart(2,"0")}h</div>
      <div class="bar-track"><div class="bar-seg A" style="width:${wA}%"></div><div class="bar-seg B" style="width:${wB}%"></div></div>
      <div class="val">${fmtNum(x.real)} <span style="color:${cor};font-weight:700">(${fmtNum(Math.round(med*10)/10)}/h)</span></div>
    </div>`;
  }).join("");
}
function renderDash(){
  const ds = document.getElementById("dashSafra"); if(ds) ds.textContent = state.config.safra || "2025/26";
  // descrição do período ativo (item 1)
  const ptxt = document.getElementById("dashPeriodoTxt");
  if(ptxt) ptxt.textContent = janelaPeriodoTxt();   // mostra o intervalo real (06:00 → 05:59:59) que está sendo puxado

  // agregados do PERÍODO, por turno (item 1 rege todos os widgets)
  const lp = lancamentosNoPeriodo();
  const ag = { A:{prod:0,horas:0,dias:new Set()}, B:{prod:0,horas:0,dias:new Set()} };
  const diasG = new Set();
  for(const l of lp){
    const g = ag[l.turno]; if(!g) continue;
    const r = calcRealizado(l.fardoInicio, l.fardoFinal);
    const h = calcHoras(l.horaInicio, l.horaFim);
    if(r!==null) g.prod += r;
    if(h!==null) g.horas += h;
    if(r!==null && l.data){ g.dias.add(l.data); diasG.add(l.data); }
  }
  const tA=ag.A.prod, tB=ag.B.prod, geral=tA+tB;
  const hA=ag.A.horas, hB=ag.B.horas, hG=hA+hB;
  const fhA = hA>0 ? tA/hA : 0, fhB = hB>0 ? tB/hB : 0, fhG = hG>0 ? geral/hG : 0;   // item 2: fardos/h = total ÷ horas
  const dA=ag.A.dias.size, dB=ag.B.dias.size, dG=diasG.size;
  const medA = dA>0 ? tA/dA : 0, medB = dB>0 ? tB/dB : 0, medG = dG>0 ? geral/dG : 0;
  const meta = state.config.metaPorHora || 17;

  // trio = A (cima) + B (baixo) + A+B (cartão alto à direita). data-count/data-dec alimentam a animação (item 5).
  function vCell(cls, titulo, num, unidade, dec){
    const fin = dec ? fmtNum(Math.round(num*10)/10) : fmtNum(Math.round(num));
    return `<div class="kpi ${cls}"><div class="l">${titulo}</div><div class="v" data-count="${num}" data-dec="${dec?1:0}">${fin}</div><div class="u">${unidade}</div></div>`;
  }
  function trio(titulo, a, b, g, unidade, dec){
    return `<div class="kpi-trio">${
      vCell("A kpi-sm", titulo+" — A", a, unidade, dec)}${
      vCell("B kpi-sm", titulo+" — B", b, unidade, dec)}${
      vCell("G", titulo+" — A+B", g, unidade, dec)}</div>`;
  }
  document.getElementById("kpis").innerHTML =
      trio("Total Produzido", tA, tB, geral, "fardos", false)
    + trio("Fardos/h médio", fhA, fhB, fhG, "fardos/h · meta "+meta, true)
    + trio("Dias com produção", dA, dB, dG, "dias", false)
    + trio("Média fardos/dia", medA, medB, medG, "fardos/dia", true);

  // gráfico Produção por Turno (A x B)
  const maxT = Math.max(tA, tB, 1);
  document.getElementById("chartTurno").innerHTML =
    [{n:"Turno A",v:tA,c:"A"},{n:"Turno B",v:tB,c:"B"}].map(x=>
      `<div class="bar-row">
        <div class="name">${x.n}</div>
        <div class="bar-track"><div class="bar-seg ${x.c}" style="width:${(x.v/maxT*100).toFixed(2)}%"></div></div>
        <div class="val">${fmtNum(x.v)}</div>
      </div>`
    ).join("");

  renderChartPorHora();   // F27 - curva de produção por hora

  // contagem de ocorrências (do PERÍODO) — A e B em barras próprias, empilhadas e coladas (item 4)
  const counts = new Map(); // cat -> {a,b}
  for(const l of lp){
    if(!l.ocorrencia) continue;
    if(!counts.has(l.ocorrencia)) counts.set(l.ocorrencia, {a:0,b:0});
    const c = counts.get(l.ocorrencia);
    if(l.turno==="A") c.a++; else c.b++;
  }
  const arr = [...counts.entries()]
    .map(([name,c])=>({name, a:c.a, b:c.b, total:c.a+c.b}))
    .filter(x=>x.total>0)
    .sort((x,y)=>y.total-x.total);

  const chart = document.getElementById("chart");
  if(arr.length===0){
    chart.innerHTML = `<div class="empty">Nenhuma ocorrência registrada no período.</div>`;
    return;
  }
  // escala pelo MAIOR valor isolado (a ou b) da lista
  const maxIso = Math.max(1, ...arr.flatMap(x=>[x.a, x.b]));
  chart.innerHTML = arr.map(x=>{
    const wA = (x.a/maxIso*100).toFixed(2), wB = (x.b/maxIso*100).toFixed(2);
    return `<div class="ocor-row">
      <div class="name">${escapeHtml(x.name)}</div>
      <div class="ocor-bars">
        <div class="ob-track"><div class="bar-seg A" style="width:${wA}%"></div></div>
        <div class="ob-track"><div class="bar-seg B" style="width:${wB}%"></div></div>
      </div>
      <div class="val">${x.total} <span style="color:#9aa5b1;font-weight:600">(${x.a}/${x.b})</span></div>
    </div>`;
  }).join("");
}

