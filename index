/* ---------- Dashboard: animação de entrada (item 5) ---------- */
function prefereSemAnimacao(){ return window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches; }
function countUp(el){
  const target = Number(el.getAttribute("data-count")) || 0;
  const dec = el.getAttribute("data-dec") === "1";
  const fmtFinal = dec ? fmtNum(Math.round(target*10)/10) : fmtNum(Math.round(target));
  const dur = 750, t0 = performance.now();
  function step(t){
    const p = Math.min(1, (t - t0) / dur);
    const e = 1 - Math.pow(1 - p, 3);              // ease-out cubic
    const v = target * e;
    el.textContent = dec ? (Math.round(v*10)/10).toFixed(1).replace(".",",") : String(Math.round(v));
    if(p < 1) requestAnimationFrame(step); else el.textContent = fmtFinal;
  }
  requestAnimationFrame(step);
}
function animarDashboard(){
  const cont = document.getElementById("view-dash"); if(!cont) return;
  if(prefereSemAnimacao()) return;                 // respeita prefers-reduced-motion
  // cartões: fade + slide-up escalonado
  cont.querySelectorAll(".kpi").forEach((c,i)=>{ c.style.animation="none"; void c.offsetWidth; c.style.animationDelay=(i*55)+"ms"; c.classList.add("anim"); });
  // números: count-up
  cont.querySelectorAll(".v[data-count]").forEach(countUp);
  // barras: crescendo a partir de 0
  cont.querySelectorAll(".bar-seg").forEach(el=>{ const w=el.style.width; if(!w) return; el.style.width="0%"; requestAnimationFrame(()=>{ el.style.width=w; }); });
}

