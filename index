// CSV para Excel (pt-BR): separador ";" e BOM para acentos abrirem certo.
function montarCSV(){
  const sep = ";";
  const safra = state.config.safra || "";
  const head = ["Safra","Turno","Data (dia produção)","Data real","Hora Início","Hora Fim","Horas","Fardo Início","Fardo Final","Meta","Realizado","Ocorrência"];
  const linhas = [head.join(sep)];
  const rows = state.lancamentos.filter(l => !isEmptyRow(l))
    .slice().sort((a,b)=> ((a.data||"")+a.turno+(a.horaInicio||"")) < ((b.data||"")+b.turno+(b.horaInicio||"")) ? -1 : 1);
  for(const l of rows){
    const horas = calcHoras(l.horaInicio, l.horaFim);
    const meta  = metaDaLinha(l);   // item 7: meta vigente
    const real  = calcRealizado(l.fardoInicio, l.fardoFinal);
    const c = [
      safra, l.turno, l.data||"", dataRealDe(l)||"", l.horaInicio||"", l.horaFim||"",
      horas===null ? "" : String(Math.round(horas*100)/100).replace(".",","),
      (l.fardoInicio===""||l.fardoInicio==null) ? "" : l.fardoInicio,
      (l.fardoFinal===""||l.fardoFinal==null) ? "" : l.fardoFinal,
      meta===null ? "" : String(Math.floor(meta)),
      real===null ? "" : String(real),
      ocorrenciaLabel(l).replace(/[;\r\n]/g," ")
    ];
    linhas.push(c.join(sep));
  }
  return "﻿" + linhas.join("\r\n");
}
