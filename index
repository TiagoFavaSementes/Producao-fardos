/* ---------- CÁLCULO POR PRESTADOR (sem rateio: crédito pela janela em que a pessoa estava) ---------- */
// Monta as janelas de uma chave "T|data" com início/fim contínuos (trata virada de meia-noite).
function janelasDoDia(turno, data){
  const js = [];
  for(const l of state.lancamentos){
    if(l.turno!==turno || l.data!==data) continue;
    const h = calcHoras(l.horaInicio, l.horaFim);
    const r = calcRealizado(l.fardoInicio, l.fardoFinal);
    const rawIni = timeToMin(l.horaInicio);
    if(h===null || r===null || rawIni===null) continue;
    js.push({ rawIni, horas:h, real:r });
  }
  if(!js.length) return null;
  // Âncora = início real do turno, robusto à ordem de digitação e à virada de meia-noite:
  // o horário logo após o MAIOR intervalo no relógio (o "buraco" entre o fim do turno e o recomeço).
  const anchor = ancoraTurno(js.map(j=>j.rawIni));
  js.forEach(j=>{ let ci=j.rawIni; if(ci<anchor) ci+=1440; j.ini=ci; j.fim=ci + j.horas*60; });
  const dayStart = Math.min.apply(null, js.map(j=>j.ini));
  const dayEnd   = Math.max.apply(null, js.map(j=>j.fim));
  return { janelas:js, anchor, dayStart, dayEnd };
}
// Início do turno a partir dos horários de início (em min): valor logo após o maior gap circular.
// Ex.: turno A {08..16} -> 08:00; turno B {19..03 + 00..03} -> 19:00 (mesmo lançado fora de ordem).
function ancoraTurno(inis){
  const u = [...new Set(inis)].sort((a,b)=>a-b);
  if(u.length<=1) return u[0]||0;
  let maxGap=-1, start=u[0];
  for(let i=0;i<u.length;i++){
    const cur=u[i], next=(i+1<u.length)?u[i+1]:u[0]+1440;
    if(next-cur>maxGap){ maxGap=next-cur; start=(i+1<u.length)?u[i+1]:u[0]; }
  }
  return start;
}
// Ancora um horário HH:MM ao turno (virada de meia-noite).
function ancorarHora(t, anchor){ let r=timeToMin(t); if(r===null) return null; if(r<anchor) r+=1440; return r; }
// Crédito por prestador numa chave: [{id,nome,horas,fardos}]. Produção CHEIA da janela (não divide).
function calcPrestadoresDoDia(turno, data){
  const g = janelasDoDia(turno, data); if(!g) return [];
  const p = state.presenca[turno+"|"+data] || {};
  const creditados = presCreditados(p);
  const ajustes = (p.ajustes && typeof p.ajustes==="object" && !Array.isArray(p.ajustes)) ? p.ajustes : {};
  const out = [];
  creditados.forEach(id=>{
    const aj = ajustes[id] || {};
    const eRaw = (aj.entrada!=null && aj.entrada!=="") ? ancorarHora(aj.entrada, g.anchor) : null;
    const sRaw = (aj.saida  !=null && aj.saida  !=="") ? ancorarHora(aj.saida,   g.anchor) : null;
    const entrada = eRaw!=null ? eRaw : g.dayStart;
    const saida   = sRaw!=null ? sRaw : g.dayEnd;
    let horas=0, fardos=0;
    g.janelas.forEach(j=>{ if(j.ini>=entrada && j.ini<saida){ horas+=j.horas; fardos+=j.real; } });
    const c = getColab(id);
    out.push({ id, nome: c?colabNome(c):"(removido)", horas, fardos });
  });
  out.sort((a,b)=> b.horas - a.horas);
  return out;
}
// Agregado da safra por prestador (para a aba Funcionários).
function calcFunc(){
  const porId = {};
  (state.funcionarios||[]).forEach(c=>{ porId[c.id] = { dias:new Set(), fardos:0, horas:0 }; });
  let totalGeral = 0;
  const chaves = new Set();
  state.lancamentos.forEach(l=>{ if(l.data) chaves.add(l.turno+"|"+l.data); });
  chaves.forEach(k=>{
    const parts = k.split("|");
    const g = janelasDoDia(parts[0], parts[1]); if(!g) return;
    g.janelas.forEach(j=> totalGeral += j.real);
    calcPrestadoresDoDia(parts[0], parts[1]).forEach(pr=>{
      if(!porId[pr.id]) porId[pr.id] = { dias:new Set(), fardos:0, horas:0 };   // presença de quem saiu do roster
      if(pr.horas>0 || pr.fardos>0){ porId[pr.id].dias.add(k); porId[pr.id].horas += pr.horas; porId[pr.id].fardos += pr.fardos; }
    });
  });
  return { porId, totalGeral };
}

/* ---------- render da aba Funcionários ---------- */
function renderRoster(){
  const tbl = document.getElementById("rosterTbl"); if(!tbl) return;
  const editar = funcPodeEditarRoster();
  const ros = state.funcionarios||[];
  let html = `<thead><tr><th>Colaborador</th><th>Turno A</th><th>Turno B</th><th></th></tr></thead><tbody>`;
  if(!ros.length){ html += `<tr><td colspan="4" class="empty">Nenhum colaborador cadastrado.</td></tr>`; }
  else ros.forEach(c=>{
    const dis = editar ? "" : " disabled";
    html += `<tr>
      <td>${escapeHtml(colabNome(c))}${c.sim?' <span class="badge-sim">sim</span>':''}</td>
      <td><input type="checkbox" aria-label="Habilitado no Turno A" data-rid="${c.id}" data-rturno="A"${colabAtivo(c,"A")?" checked":""}${dis}></td>
      <td><input type="checkbox" aria-label="Habilitado no Turno B" data-rid="${c.id}" data-rturno="B"${colabAtivo(c,"B")?" checked":""}${dis}></td>
      <td class="col-acao">${editar?`<button class="btn-del" data-rdel="${c.id}" title="Remover" aria-label="Remover colaborador">✕</button>`:""}</td>
    </tr>`;
  });
  tbl.innerHTML = html + `</tbody>`;
}
function renderFuncCalc(){
  const tbl = document.getElementById("funcCalcTbl"); if(!tbl) return;
  const { porId } = calcFunc();
  const linhas = (state.funcionarios||[]).map(c=>({ c, d: porId[c.id] || {dias:new Set(),fardos:0,horas:0} }))
    .filter(x=> x.d.fardos>0 || x.d.horas>0 || x.d.dias.size>0)
    .sort((a,b)=> b.d.horas - a.d.horas);
  let html = `<thead><tr><th>Colaborador</th><th>Dias</th><th>Horas</th><th>Fardos atribuídos</th><th>Fardos/h</th></tr></thead><tbody>`;
  if(!linhas.length){ html += `<tr><td colspan="5" class="empty">Sem presença/produção registrada ainda.</td></tr>`; }
  else linhas.forEach(({c,d})=>{
    const fh = d.horas>0 ? d.fardos/d.horas : 0;
    html += `<tr><td>${escapeHtml(colabNome(c))}</td><td>${d.dias.size}</td><td>${fmtHoras(d.horas)}</td><td>${fmtNum(Math.round(d.fardos))}</td><td>${fmtNum(Math.round(fh*10)/10)}</td></tr>`;
  });
  tbl.innerHTML = html + `</tbody>`;
}
function renderFunc(){
  const addForm = document.getElementById("funcAddForm");
  if(addForm) addForm.style.display = funcPodeEditarRoster() ? "" : "none";
  renderRoster(); renderFuncCalc();
}

/* ---------- CHAMADAS (roll-call) ---------- */
let _chamadaCtx = null;   // { fase:"inicio"|"fim", turno, data, inicioSet?, resolve? }

// CHAMADA DE INÍCIO — no "Iniciar o dia". Não abre se não houver colaborador habilitado no turno.
function abrirChamadaInicio(turno, data){
  if(!temElegiveis(turno)) return;
  const k = turno+"|"+data;
  const p = state.presenca[k] || { inicio:[], fim:[], ajustes:{} };
  const jaInicio = new Set(p.inicio||[]);
  _chamadaCtx = { fase:"inicio", turno, data };
  document.getElementById("funcModalTitulo").textContent = `Chamada de início — Turno ${turno} · ${fmtDateBR(data)}`;
  document.getElementById("funcModalSub").textContent = "Marque quem está presente no início do turno.";
  const elegiveis = (state.funcionarios||[]).filter(c=>colabAtivo(c,turno));
  document.getElementById("funcModalLista").innerHTML = elegiveis.map(c=>
    `<label class="chamada-item"><input type="checkbox" data-pid="${c.id}"${jaInicio.has(c.id)?" checked":""}><span>${escapeHtml(colabNome(c))}</span></label>`
  ).join("");
  document.getElementById("funcModalAdd").style.display = funcPodeEditarRoster() ? "" : "none";
  document.getElementById("funcModalPular").textContent = "Pular";
  document.getElementById("funcModalSalvar").textContent = "Salvar chamada";
  document.getElementById("funcModal").classList.remove("hidden");
}

// CHAMADA DE FIM — no "Concluir o dia", ANTES do PDF. Promise: resolve {ok}/{skip} ou null (cancelado).
function abrirChamadaFim(turno, data){
  return new Promise(resolve=>{
    const k = turno+"|"+data;
    const p = state.presenca[k] || { inicio:[], fim:[], ajustes:{} };
    if(!temElegiveis(turno) && !(p.inicio||[]).length){ resolve({ skip:true }); return; }   // nada a reconciliar
    const inicioVazio = !(p.inicio && p.inicio.length);   // início pulado -> sem reconciliação (turno cheio)
    const inicioSet = new Set(p.inicio||[]);
    const fimSet = (p.fim && p.fim.length) ? new Set(p.fim) : new Set(p.inicio||[]);   // default: quem começou continua
    const aj = (p.ajustes && typeof p.ajustes==="object" && !Array.isArray(p.ajustes)) ? p.ajustes : {};
    _chamadaCtx = { fase:"fim", turno, data, inicioSet, inicioVazio, ajustes:aj, resolve };
    // lista = habilitados no turno ∪ quem estava no início (mesmo que tenha saído do roster)
    const ids = [];
    (state.funcionarios||[]).forEach(c=>{ if(colabAtivo(c,turno) || inicioSet.has(c.id)) ids.push(c.id); });
    (p.inicio||[]).forEach(id=>{ if(ids.indexOf(id)<0) ids.push(id); });
    document.getElementById("funcModalTitulo").textContent = `Chamada de fim — Turno ${turno} · ${fmtDateBR(data)}`;
    document.getElementById("funcModalSub").textContent = "Confirme quem está no fim do turno. Quem saiu antes ou entrou depois, informe o horário.";
    document.getElementById("funcModalLista").innerHTML = ids.map(id=>{
      const c = getColab(id); const nome = c?colabNome(c):"(removido)";
      const noInicio = inicioSet.has(id), noFim = fimSet.has(id);
      const ajv = aj[id]||{};
      return `<div class="chamada-row" data-row="${id}">
        <label class="chamada-item"><input type="checkbox" data-fid="${id}"${noFim?" checked":""}><span>${escapeHtml(nome)}</span>
          <em class="chamada-tag">${noInicio?"estava no início":"não estava no início"}</em></label>
        <div class="chamada-hora" data-hora="${id}" style="display:none">
          <label class="chamada-hlbl"></label>
          <input type="time" data-hid="${id}" data-htipo="" aria-label="Horário" value="${escapeHtml(ajv.saida||ajv.entrada||"")}">
        </div>
      </div>`;
    }).join("");
    document.getElementById("funcModalAdd").style.display = funcPodeEditarRoster() ? "" : "none";
    document.getElementById("funcModalPular").textContent = "Cancelar";
    document.getElementById("funcModalSalvar").textContent = "Salvar e continuar";
    atualizarLinhasFim();
    document.getElementById("funcModal").classList.remove("hidden");
  });
}
// Mostra/oculta o campo de hora de cada linha do fim conforme início × presença no fim.
function atualizarLinhasFim(){
  const ctx = _chamadaCtx || {};
  const inicioSet = ctx.inicioSet || new Set();
  const ajustes = ctx.ajustes || {};
  const inicioVazio = !!ctx.inicioVazio;
  document.querySelectorAll("#funcModalLista .chamada-row").forEach(row=>{
    const id = row.getAttribute("data-row");
    const cb = row.querySelector("[data-fid]");
    const box = row.querySelector("[data-hora]");
    const inp = row.querySelector("[data-hid]");
    const lbl = row.querySelector(".chamada-hlbl");
    const noInicio = inicioSet.has(id), noFim = cb.checked;
    let tipo = "";
    if(!inicioVazio){                                 // sem início registrado -> ninguém exige horário (turno cheio)
      if(noInicio && !noFim) tipo = "saida";          // estava no início e saiu antes
      else if(!noInicio && noFim) tipo = "entrada";   // não estava no início e entrou depois
    }
    const prevTipo = inp.getAttribute("data-htipo") || "";
    if(tipo !== prevTipo){
      // tipo mudou -> mostra o ajuste da categoria certa (ou limpa); preserva o que já foi digitado p/ o mesmo tipo
      const ajv = ajustes[id] || {};
      inp.value = tipo==="saida" ? (ajv.saida||"") : tipo==="entrada" ? (ajv.entrada||"") : "";
    }
    inp.setAttribute("data-htipo", tipo);
    if(tipo){ box.style.display = ""; lbl.textContent = tipo==="saida" ? "Saiu às:" : "Entrou às:"; }
    else { box.style.display = "none"; }
  });
}
function appendFimRow(id){
  const c = getColab(id); const nome = c?colabNome(c):"(removido)";
  const div = document.createElement("div");
  div.className = "chamada-row"; div.setAttribute("data-row", id);
  div.innerHTML = `<label class="chamada-item"><input type="checkbox" data-fid="${id}" checked><span>${escapeHtml(nome)}</span>
      <em class="chamada-tag">não estava no início</em></label>
    <div class="chamada-hora" data-hora="${id}" style="display:none"><label class="chamada-hlbl"></label>
      <input type="time" data-hid="${id}" data-htipo="" aria-label="Horário" value=""></div>`;
  document.getElementById("funcModalLista").appendChild(div);
}

function fecharChamada(){
  document.getElementById("funcModal").classList.add("hidden");
  const ctx = _chamadaCtx; _chamadaCtx = null;
  if(ctx && ctx.fase==="fim" && ctx.resolve) ctx.resolve(null);   // cancelou a chamada de fim -> conclusão aborta
}
function salvarChamada(){
  const ctx = _chamadaCtx; if(!ctx){ fecharChamada(); return; }
  const k = ctx.turno+"|"+ctx.data;
  const p = state.presenca[k] || { inicio:[], fim:[], ajustes:{} };

  if(ctx.fase==="inicio"){
    p.inicio = [...document.querySelectorAll('#funcModalLista [data-pid]:checked')].map(cb=>cb.getAttribute("data-pid"));
    state.presenca[k] = p;
    save(); subirPresenca(k); renderFunc();
    fecharChamada();
    toast(`Chamada de início salva: ${p.inicio.length} presente(s).`);
    return;
  }

  // FASE FIM: valida horários obrigatórios e monta fim + ajustes.
  const fim = [], ajustes = {};
  let faltando = null;
  const rows = [...document.querySelectorAll('#funcModalLista .chamada-row')];
  for(const row of rows){
    const id = row.getAttribute("data-row");
    const cb = row.querySelector("[data-fid]");
    const inp = row.querySelector("[data-hid]");
    const tipo = inp.getAttribute("data-htipo");
    const val = (inp.value||"").trim();
    const c = getColab(id); const nome = c?colabNome(c):"(removido)";
    if(cb.checked) fim.push(id);
    if(tipo==="saida"){ if(!val){ faltando = "Informe o horário de SAÍDA de " + nome + "."; break; } ajustes[id] = { saida:val }; }
    else if(tipo==="entrada"){ if(!val){ faltando = "Informe o horário de ENTRADA de " + nome + "."; break; } ajustes[id] = { entrada:val }; }
  }
  if(faltando){ toast("⚠ " + faltando, 4800); return; }   // bloqueia: não fecha o modal

  p.fim = fim; p.ajustes = ajustes;
  if(!(p.inicio && p.inicio.length)) p.inicio = fim.slice();   // sem início registrado -> turno cheio
  state.presenca[k] = p;
  // NÃO dispara upload aqui: o flushSync do concluirDia sobe a presença junto (evita corrida com o upload).
  save(); addPend("pres:"+k); atualizarBarraPend(); renderFunc();
  const resolve = ctx.resolve; ctx.resolve = null;   // evita resolve duplo no fecharChamada
  fecharChamada();
  if(resolve) resolve({ ok:true, presenca:p });
}
function addColabModal(){
  if(!funcPodeEditarRoster()){ toast("Apenas ADM/Suporte cadastram colaboradores. Peça ao ADM."); return; }
  const n=document.getElementById("funcModalNome"), s=document.getElementById("funcModalSobrenome");
  const nome=(n.value||"").trim(); if(!nome){ n.focus(); return; }
  const c = { id:fid(), nome, sobrenome:(s.value||"").trim(), ativoA:true, ativoB:true };
  if(!Array.isArray(state.funcionarios)) state.funcionarios = [];
  state.funcionarios.push(c);
  persistirRoster();
  n.value=""; s.value=""; n.focus();
  const ctx = _chamadaCtx; if(!ctx) return;
  if(ctx.fase==="inicio"){
    abrirChamadaInicio(ctx.turno, ctx.data);
    const cb = document.querySelector(`#funcModalLista [data-pid="${c.id}"]`); if(cb) cb.checked = true;
  } else {
    appendFimRow(c.id); atualizarLinhasFim();
  }
}

// Simulação de funcionários — agora popula state.funcionarios / state.presenca (formato novo).
function simularFuncionarios(){
  if(!Array.isArray(state.funcionarios) || !state.funcionarios.length){
    const ex = [["João","Silva"],["Pedro","Souza"],["Maria","Lima"],["Ana","Costa"],["Carlos","Rocha"],["José","Alves"]];
    state.funcionarios = ex.map(([n,s])=>({ id:fid(), nome:n, sobrenome:s, ativoA:true, ativoB:true, sim:true }));
  }
  if(!state.presenca || typeof state.presenca!=="object") state.presenca = {};
  const ids = state.funcionarios.map(c=>c.id);
  const chaves = new Set();
  state.lancamentos.forEach(l=>{ if(l.sim && l.data) chaves.add(l.turno+"|"+l.data); });
  chaves.forEach(k=>{
    const n = randInt(3, Math.min(5, ids.length));
    const presentes = ids.slice().sort(()=>Math.random()-0.5).slice(0,n);
    state.presenca[k] = { inicio:presentes, fim:presentes.slice(), ajustes:{}, sim:true };   // marca p/ excluirSimulacao
  });
  // quem chamou (gerarSimulacao) faz save()+renderAll()
}

/* eventos da aba Funcionários */
document.getElementById("btnFuncAdd").addEventListener("click", ()=>{
  if(!funcPodeEditarRoster()){ toast("Apenas ADM/Suporte cadastram colaboradores."); return; }
  const n=document.getElementById("funcNome"), s=document.getElementById("funcSobrenome");
  const nome=(n.value||"").trim(); if(!nome){ n.focus(); return; }
  if(!Array.isArray(state.funcionarios)) state.funcionarios = [];
  state.funcionarios.push({ id:fid(), nome, sobrenome:(s.value||"").trim(), ativoA:true, ativoB:true });
  persistirRoster(); n.value=""; s.value="";
});
document.getElementById("rosterTbl").addEventListener("change", e=>{
  const cb = e.target.closest("[data-rid]"); if(!cb) return;
  if(!funcPodeEditarRoster()){ renderRoster(); return; }
  const c = getColab(cb.getAttribute("data-rid")); if(!c) return;
  if(cb.getAttribute("data-rturno")==="A") c.ativoA = cb.checked; else c.ativoB = cb.checked;
  persistirRoster();
});
document.getElementById("rosterTbl").addEventListener("click", e=>{
  const del = e.target.closest("[data-rdel]"); if(!del) return;
  if(!funcPodeEditarRoster()){ toast("Apenas ADM/Suporte."); return; }
  const id = del.getAttribute("data-rdel");
  if(!confirm("Remover este colaborador? (a presença já registrada nos dias é mantida)")) return;
  state.funcionarios = (state.funcionarios||[]).filter(x=>x.id!==id);
  persistirRoster();
});
document.getElementById("funcModalSalvar").addEventListener("click", salvarChamada);
document.getElementById("funcModalPular").addEventListener("click", fecharChamada);
document.getElementById("btnFuncModalAdd").addEventListener("click", addColabModal);
document.getElementById("funcModalLista").addEventListener("change", e=>{
  if(_chamadaCtx && _chamadaCtx.fase==="fim" && e.target.closest("[data-fid]")) atualizarLinhasFim();
});

