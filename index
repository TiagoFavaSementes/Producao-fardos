}
agendarCheckImportar();

/* ---------- utilidades de cálculo ---------- */
const uid = () => "l_" + Date.now().toString(36) + Math.random().toString(36).slice(2,7);

function timeToMin(t){
  if(!t) return null;
  const p = String(t).split(":");
  const h = Number(p[0]), m = Number(p[1]);
  if(isNaN(h) || isNaN(m)) return null;
  return h*60 + m;
}
// Virada de meia-noite aplicada aos dois turnos por segurança.
function calcHoras(inicio, fim){
  const a = timeToMin(inicio), b = timeToMin(fim);
  if(a===null || b===null) return null;
  let diff = b - a;
  if(diff < 0) diff += 1440;
  return diff/60;                       // horas decimais
}
function calcMeta(horas){
  if(horas===null) return null;
  return horas * state.config.metaPorHora;
}
// Item 7 - meta efetiva POR HORA: cai para a meta de ajuste quando a ocorrência é "AJUSTES INICIAIS/OPERACIONAIS".
function metaEfetiva(l){
  return (l && l.ocorrencia === "AJUSTES INICIAIS/OPERACIONAIS")
    ? (state.config.metaAjuste || 10)
    : (state.config.metaPorHora || 17);
}
// Meta vigente da JANELA (linha) = meta efetiva/hora × horas da janela.
function metaDaLinha(l){
  const h = calcHoras(l.horaInicio, l.horaFim);
  return h===null ? null : h * metaEfetiva(l);
}
function calcRealizado(fi, ff){
  if(ff===""||ff===null||ff===undefined) return null;
  const b = Number(ff);
  if(isNaN(b)) return null;
  const a = (fi===""||fi===null||fi===undefined||isNaN(Number(fi))) ? 0 : Number(fi);
  return b - a;
}
function plural(n){ return n===1 ? "Fardo" : "Fardos"; }

// Regra de status (recebe produção e meta já somadas). text = completo; short = curto p/ o resumo.
function statusInfo(prod, meta){
  if(prod===null || meta===null) return { text:"—", short:"—", cls:"" };
  const metaInt = Math.floor(meta);
  if(prod > metaInt){ const n = prod-metaInt; return { text:`Acima da Meta [ +${n} ${plural(n)} ]`, short:`+${n} ${plural(n).toLowerCase()}`, cls:"st-acima" }; }
  if(prod === metaInt){ return prod===0 ? { text:"Sem Produção", short:"Sem produção", cls:"" } : { text:"Meta batida", short:"Meta batida", cls:"st-acima" }; }
  const n = metaInt - prod;
  return { text:`Abaixo da Meta [ -${n} ${plural(n)} ]`, short:`-${n} ${plural(n).toLowerCase()}`, cls:"st-abaixo" };
}

// F2 - Validação de produção fora do normal: bloqueia avançar e alerta.
const FATOR_OUTLIER = 2;   // rodada 12: realizado acima de meta*2 = provável erro de digitação (antes 3)
function motivoRealizadoInvalido(l){
  const real = calcRealizado(l.fardoInicio, l.fardoFinal);
  if(real===null) return null;
  if(real < 0) return "O Fardo Final está MENOR que o Fardo Início (produção negativa). Confira os números.";
  const meta = metaDaLinha(l);   // rodada 12: meta VIGENTE da janela (respeita a meta de ajuste = 10)
  if(meta!==null && meta>0 && real > meta*FATOR_OUTLIER)
    return "Produção muito acima do normal (mais de "+FATOR_OUTLIER+"x a meta da janela). Confira o Fardo Final — provável erro de digitação.";
  return null;
}

// Item 8 - categorias que envolvem descaroçador (mostram o seletor 1-7) + opções do seletor (7 = backup).
function envolveDescarocador(ocor){ return !!ocor && (state.config.descarocadorCats||[]).includes(ocor); }
function descarocadorOptions(sel){
  let o = "";
  for(let i=1;i<=7;i++){ o += `<option value="${i}"${String(sel)===String(i)?" selected":""}>${i===7?"7 (backup)":i}</option>`; }
  return o;
}
// Item 9 - "motivo informado" = ocorrência preenchida (e, se OUTROS, com texto).
function temMotivo(l){
  if(!l.ocorrencia) return false;
  if(l.ocorrencia === "OUTROS") return !!(l.outrosTexto && String(l.outrosTexto).trim());
  return true;
}
// Item 9 - retorna a mensagem (tooltip) se a linha exige motivo e ainda não tem; senão null.
// Regra (rodada 12): hora completa com realizado <= metaVigente - 3 sem motivo OU OUTROS sem texto.
function motivoObrigatorioPendente(l){
  if(l.ocorrencia === "OUTROS" && !(l.outrosTexto && String(l.outrosTexto).trim()))
    return "Descreva o motivo no campo de “Outros”.";
  const real = calcRealizado(l.fardoInicio, l.fardoFinal);
  const metaJan = metaDaLinha(l);
  if(real!==null && metaJan!==null && real <= metaJan - 3 && !temMotivo(l))
    return "Informe o motivo da baixa produção nesta hora.";
  return null;
}
// Texto da ocorrência para Resumo/relatórios: anexa nº do descaroçador e o texto de "Outros".
function ocorrenciaLabel(l){
  if(!l || !l.ocorrencia) return "";
  if(l.ocorrencia === "OUTROS") return "Outros: " + (l.outrosTexto ? String(l.outrosTexto) : "—");
  if(envolveDescarocador(l.ocorrencia)) return l.ocorrencia + " (Descaroçador " + (l.descarocador || 7) + ")";
  return l.ocorrencia;
}

function fmtNum(n){ return Number.isInteger(n) ? String(n) : n.toFixed(1).replace(".",","); }
function fmtHoras(h){ return fmtNum(Math.round(h*100)/100) + "h"; }
function fmtDateBR(iso){
  if(!iso) return "";
  const p = iso.split("-");
  return p.length===3 ? `${p[2]}/${p[1]}/${p[0]}` : iso;
}

/* ---------- helpers de dados ---------- */
function rowsOf(turno){ return state.lancamentos.filter(l => l.turno===turno); }
function chaveDia(turno, data){ return turno + "|" + data; }
function isConcluido(turno, data){ return state.concluidos.includes(chaveDia(turno, data)); }
function isIniciado(turno, data){ return (state.iniciados||[]).includes(chaveDia(turno, data)); }
function diaTrabalho(turno){ const el=document.getElementById(turno==="A"?"diaA":"diaB"); return el ? el.value : ""; }

// Linha travada (read-only)? Offline e ADM/Suporte editam tudo. USUÁRIO só edita o
// próprio dia INICIADO e NÃO concluído. Linha em branco usa o "dia de trabalho" da barra.
function diaBloqueado(turno, data){
  if(!ONLINE || ehADM()) return false;
  const dia = data || diaTrabalho(turno);
  if(!dia) return true;
  if(isConcluido(turno, dia)) return true;
  if(dia !== diaAutorizado) return true;     // só edita o dia autorizado nesta sessão (após Iniciar o dia)
  return false;
}
/* ----- LIMITE DE EXCLUSÃO DO USUÁRIO (rodada 12.1) -----
   USUÁRIO só pode excluir as 2 ÚLTIMAS linhas CRIADAS do dia, e isso NÃO regride:
   cada linha recebe um "seq" (ordem de criação) e a marca d'água (maior seq já criado no dia)
   nunca diminui — guardada em localStorage, sobrevive à exclusão. Assim, depois que uma linha
   fica "soterrada" por 2 lançamentos, ela trava de vez (mesmo apagando as de cima e lançando outra). */
const SEQ_KEY = "quadro_seqmax_2026";
function lerSeqMax(){ try{ const o=JSON.parse(localStorage.getItem(SEQ_KEY)); return (o&&typeof o==="object")?o:{}; }catch(e){ return {}; } }
function gravarSeqMax(key, v){ const o=lerSeqMax(); if(!(o[key]>=v)){ o[key]=v; try{ localStorage.setItem(SEQ_KEY, JSON.stringify(o)); }catch(e){} } }
function maxSeqLinhas(key){ let m=0; for(const l of state.lancamentos){ if((l.turno+"|"+l.data)===key && typeof l.seq==="number" && l.seq>m) m=l.seq; } return m; }
function pisoSeqDia(key){ return Math.max(lerSeqMax()[key]||0, maxSeqLinhas(key)); }   // marca d'água: NUNCA regride
// Carimba "seq" (ordem de criação) nas linhas reais do turno que ainda não têm. Roda no renderLanc.
function carimbarSeqs(turno){
  const porKey = {};
  for(const l of state.lancamentos){
    if(l.turno!==turno || isEmptyRow(l) || !l.data) continue;
    (porKey[l.turno+"|"+l.data] = porKey[l.turno+"|"+l.data] || []).push(l);
  }
  let mudou = false;
  for(const key in porKey){
    let H = pisoSeqDia(key);
    for(const l of porKey[key]){ if(typeof l.seq!=="number"){ l.seq = ++H; mudou = true; } }
    gravarSeqMax(key, H);
  }
  if(mudou) save();   // persiste os seq novos (sobe na próxima sincronização)
}
// Pode excluir esta linha? Offline/ADM/Suporte: sim. USUÁRIO: só as 2 ÚLTIMAS CRIADAS do dia em edição.
function podeExcluirLinha(turno, l){
  if(!ONLINE || ehADM()) return true;
  if(isEmptyRow(l)) return false;
  if(isConcluido(turno, l.data)) return false;
  if(l.data !== diaAutorizado) return false;          // USUÁRIO só mexe no dia autorizado nesta sessão
  if(typeof l.seq !== "number") return false;         // sem ordem de criação -> travada
  return l.seq >= pisoSeqDia(turno+"|"+l.data) - 1;   // só os 2 últimos seq (marca d'água não regride)
}
// Maior FARDO FINAL já lançado em qualquer turno (contador contínuo). Exclui uma linha opcional.
function proximoFardoInicio(excludeId){
  let max = null;
  for(const l of state.lancamentos){
    if(excludeId && l.id===excludeId) continue;
    if(l.fardoFinal===""||l.fardoFinal==null) continue;
    const v = Number(l.fardoFinal);
    if(!isNaN(v) && (max===null || v>max)) max = v;
  }
  return max;   // número ou null
}
// HORA FIM da última linha real do turno -> sugestão de HORA INÍCIO da próxima janela.
function proximaHoraInicio(turno, excludeId){
  const reais = rowsOf(turno).filter(l => !isEmptyRow(l) && (!excludeId || l.id!==excludeId));
  const ultima = reais[reais.length-1];
  return (ultima && ultima.horaFim) ? ultima.horaFim : null;
}

/* ---------- DATA REAL (calendário) por linha ----------
   A coluna "Data" mostra l.dataReal (data do calendário daquela hora). l.data continua sendo o
   "dia de produção" (o turno é UMA unidade p/ iniciar/concluir, mesmo cruzando a meia-noite).
   dataReal puxa a do lançamento anterior e AVANÇA 1 dia quando a janela anterior cruza 00:00. */
function addDias(iso, n){ const p=String(iso).split("-"); if(p.length!==3) return iso; const d=new Date(Number(p[0]),Number(p[1])-1,Number(p[2])); if(isNaN(d.getTime())) return iso; d.setDate(d.getDate()+n); return isoLocal(d); }
function cruzouMeiaNoite(l){ const a=timeToMin(l.horaInicio), b=timeToMin(l.horaFim); return (a!==null && b!==null && b < a); }   // ex.: 23:00→00:00
function dataRealDe(l){ return l.dataReal || l.data || ""; }
function proximaDataReal(turno, excludeId){
  const reais = rowsOf(turno).filter(l => !isEmptyRow(l) && (!excludeId || l.id!==excludeId));
  const ultima = reais[reais.length-1];
  if(!ultima) return diaTrabalho(turno) || "";                      // 1ª linha do turno: dia da barra
  const base = dataRealDe(ultima) || diaTrabalho(turno) || "";
  if(!base) return "";
  return cruzouMeiaNoite(ultima) ? addDias(base, 1) : base;         // depois de cruzar 00:00 → dia seguinte
}
// Mensagem específica se a linha está incompleta/mal preenchida (data/hora fora do padrão, fardos faltando).
function motivoLinhaIncompleta(l){
  if(!l.data && !l.dataReal) return "Preencha a DATA (dd/mm/aaaa).";
  if(!l.horaInicio) return "Preencha a HORA INÍCIO (hh:mm).";
  if(!l.horaFim) return "Preencha a HORA FIM (hh:mm).";
  const h = calcHoras(l.horaInicio, l.horaFim);
  if(h===null) return "Horário fora do padrão (use hh:mm).";
  if(h<=0) return "A HORA FIM precisa ser depois da HORA INÍCIO.";
  if(l.fardoInicio===""||l.fardoInicio==null) return "Preencha o FARDO INÍCIO.";
  if(l.fardoFinal===""||l.fardoFinal==null) return "Preencha o FARDO FINAL.";
  if(calcRealizado(l.fardoInicio,l.fardoFinal) < 0) return "FARDO FINAL menor que o FARDO INÍCIO (produção negativa).";
  return null;
}

// Dia autorizado nesta sessão (após "Iniciar o dia"). Reseta a cada login.
let diaAutorizado = null;
// É a linha de entrada (a última do turno = a que está sendo preenchida)?
function isEntrada(turno, l){ const rows = rowsOf(turno); return rows.length>0 && rows[rows.length-1].id === l.id; }
// Linha totalmente e corretamente preenchida?
function linhaCompleta(l){
  if(!l.data || !l.horaInicio || !l.horaFim) return false;
  if(l.fardoInicio===""||l.fardoInicio==null) return false;
  if(l.fardoFinal===""||l.fardoFinal==null) return false;
  const real = calcRealizado(l.fardoInicio, l.fardoFinal);
  if(real===null || real < 0) return false;          // fardo final < início = errado
  const horas = calcHoras(l.horaInicio, l.horaFim);
  if(horas===null || horas <= 0) return false;
  if(motivoRealizadoInvalido(l)) return false;       // F2: bloqueia produção fora do normal
  return true;
}
function isEmptyRow(l){
  return !l.data && !l.horaInicio && !l.horaFim &&
         (l.fardoInicio===""||l.fardoInicio==null) &&
         (l.fardoFinal===""||l.fardoFinal==null) && !l.ocorrencia;
}
// Garante EXATAMENTE uma linha em branco no turno (a linha de entrada, exibida no topo).
function ensureTrailingBlank(turno){
  const vazias = rowsOf(turno).filter(isEmptyRow);
  if(vazias.length > 1){
    const manter = vazias[vazias.length-1].id;
    state.lancamentos = state.lancamentos.filter(l => l.turno!==turno || !isEmptyRow(l) || l.id===manter);
  }
  if(rowsOf(turno).filter(isEmptyRow).length === 0){
    state.lancamentos.push({ id:uid(), turno, data:"", horaInicio:"", horaFim:"", fardoInicio:"", fardoFinal:"", ocorrencia:"" });
  }
}

/* ============================================================
   RENDER — telas de lançamento
   ============================================================ */
function catOptions(sel){
  let o = `<option value=""></option>`;
  for(const c of state.config.categorias){
    o += `<option value="${escapeHtml(c)}"${c===sel?" selected":""}>${escapeHtml(c)}</option>`;
  }
  return o;
}
function escapeHtml(s){ return String(s).replace(/[&<>"]/g, c=>({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;"}[c])); }

function renderLanc(turno){
  ensureTrailingBlank(turno);
  carimbarSeqs(turno);            // rodada 12.1: ordem de criação p/ limitar exclusão do usuário
  const rows = rowsOf(turno);
  const tbl = document.getElementById(turno==="A" ? "tblA" : "tblB");
  let html = `<thead><tr>
      <th>Data</th><th>Hora Início</th><th>Hora Fim</th><th>Horas Prod.</th>
      <th>Fardo Início</th><th>Fardo Final</th><th>Meta</th><th>Realizado</th>
      <th>Ocorrência</th><th class="col-acao"></th>
    </tr></thead><tbody>`;

  // Total do turno (soma de todas as linhas, independente da ordem de exibição)
  let total = 0;
  for(const l of rows){ const r=calcRealizado(l.fardoInicio,l.fardoFinal); if(r!==null) total += r; }

  // Ordem de exibição: linha(s) nova(s) no TOPO, depois mais recente -> mais antiga
  const blanks = rows.filter(isEmptyRow);
  const filled = rows.filter(l => !isEmptyRow(l));
  const display = blanks.concat(filled.reverse());
  const sugFardo = proximoFardoInicio();
  const sugHora  = proximaHoraInicio(turno);
  const sugData  = proximaDataReal(turno);   // data real sugerida p/ a linha nova (puxa anterior, +1 após meia-noite)

  for(const l of display){
    const horas = calcHoras(l.horaInicio, l.horaFim);
    const meta  = metaDaLinha(l);   // item 7: meta vigente (10 em ajustes, senão 17 × horas)
    const real  = calcRealizado(l.fardoInicio, l.fardoFinal);

    const horasCell = horas===null ? `<span class="wait">Aguardando...</span>` : fmtHoras(horas);
    const metaCell  = meta===null  ? `<span class="wait">Aguardando...</span>` : fmtNum(Math.round(meta*10)/10);
    const realCell  = real===null  ? `<span class="wait">Aguardando...</span>` : fmtNum(real);
    // F26 - cor do Realizado por hora (compara com a meta da própria janela)
    const metaFloor = meta===null ? null : Math.floor(meta);
    let realCls = "";
    if(real!==null){
      if(motivoRealizadoInvalido(l)) realCls = " erro";
      else if(metaFloor!==null) realCls = (real >= metaFloor) ? " ok" : " abaixo";
    }

    const ehNova = isEmptyRow(l);
    // Sugestões na linha nova: FARDO INÍCIO = último fardo final; HORA INÍCIO = última hora fim
    const fiShown = (ehNova && (l.fardoInicio===""||l.fardoInicio==null) && sugFardo!==null) ? sugFardo : (l.fardoInicio??"");
    const hiShown = (ehNova && !l.horaInicio && sugHora) ? sugHora : (l.horaInicio||"");
    const dataShown = (ehNova && !dataRealDe(l) && sugData) ? sugData : dataRealDe(l);   // coluna Data = data real do calendário

    const bloq = diaBloqueado(turno, l.data);
    const dis  = bloq ? " disabled" : "";
    let acao = "";
    if(isEntrada(turno, l)){
      if(!bloq && linhaCompleta(l)){
        const pend = motivoObrigatorioPendente(l);   // item 9
        acao = pend
          ? `<button class="btn-prox bloq" data-prox="${l.id}" title="${escapeHtml(pend)}">✓ próxima</button>`
          : `<button class="btn-prox" data-prox="${l.id}" title="Concluir esta hora e ir para a próxima">✓ próxima</button>`;
      }
    } else if(podeExcluirLinha(turno, l)){
      acao = `<button class="btn-del" data-del="${l.id}" title="Excluir linha">✕</button>`;
    } else if(bloq){
      acao = `<span class="cadeado" title="Linha travada">🔒</span>`;
    }
    const invalida = !bloq && !!motivoRealizadoInvalido(l);                 // negativa ou > 2x a meta (vermelho)
    const faltaMot = !bloq && !ehNova && !invalida && !!motivoObrigatorioPendente(l);   // baixa produção sem motivo (âmbar; não se já é inválida)
    const cls = (bloq?" travada":"") + (ehNova?" row-nova":"") + (invalida?" linha-invalida":(faltaMot?" linha-falta-motivo":""));

    html += `<tr data-id="${l.id}"${cls.trim()?` class="${cls.trim()}"`:""}>
      <td data-label="Data"><input type="date"  data-f="data"        value="${dataShown}"${dis}></td>
      <td data-label="Hora Início"><input type="time"  data-f="horaInicio"  value="${hiShown}"${dis}></td>
      <td data-label="Hora Fim"><input type="time"  data-f="horaFim"     value="${l.horaFim||""}"${dis}></td>
      <td class="calc" data-label="Horas">${horasCell}</td>
      <td class="num" data-label="Fardo Início"><input type="number" min="0" step="1" data-f="fardoInicio" value="${fiShown}"${dis}></td>
      <td class="num" data-label="Fardo Final"><input type="number" min="0" step="1" data-f="fardoFinal"  value="${l.fardoFinal??""}"${dis}></td>
      <td class="calc" data-label="Meta">${metaCell}</td>
      <td class="calc realizado${realCls}" data-label="Realizado">${realCell}</td>
      <td data-label="Ocorrência"><div class="ocor-wrap"><select data-f="ocorrencia"${dis}>${catOptions(l.ocorrencia)}</select>${
        envolveDescarocador(l.ocorrencia) ? `<select data-f="descarocador" class="sub-ctl"${dis} title="Descaroçador (7 = backup)">${descarocadorOptions(l.descarocador||7)}</select>` : ""
      }${
        l.ocorrencia==="OUTROS" ? `<input type="text" data-f="outrosTexto" class="sub-ctl" placeholder="descreva o motivo..." value="${escapeHtml(l.outrosTexto||"")}"${dis}>` : ""
      }${
        faltaMot ? `<span class="motivo-aviso">⚠ ${escapeHtml(motivoObrigatorioPendente(l))}</span>` : ""
      }</div></td>
      <td class="col-acao" data-label="">${acao}</td>
    </tr>`;
  }
  html += `</tbody>`;
  tbl.innerHTML = html;
  document.getElementById(turno==="A"?"totalA":"totalB").textContent = fmtNum(total);
  updateConcluirBar(turno);
}

// Atualiza a barra "Concluir o dia": data padrão + situação do dia escolhido.
function updateConcluirBar(turno){
  const inp = document.getElementById(turno==="A" ? "diaA" : "diaB");
  const lbl = document.getElementById(turno==="A" ? "statusDiaA" : "statusDiaB");
  if(!inp) return;
  if(!inp.value){
    const datas = rowsOf(turno).map(l=>l.data).filter(Boolean).sort();
    inp.value = datas.length ? datas[datas.length-1] : new Date().toISOString().slice(0,10);
  }
  const data = inp.value;
  const g = computeDaySummary(turno, data);
  const concl = isConcluido(turno, data);
  const autorizado = (data === diaAutorizado);
  let estado;
  if(concl) estado = `<span style="color:#1b8a3a">✓ concluído (travado)</span>`;
  else if(ONLINE && !ehADM() && !autorizado) estado = `<span style="color:#b06a00">🔒 travado — clique “Iniciar o dia”</span>`;
  else estado = `<span style="color:#2e7d32">editável</span>`;
  const cont = g.linhas>0 ? `${g.linhas} linha(s) · ${fmtNum(g.prod)} fardos · ` : "";
  lbl.innerHTML = cont + estado;
  // Botão "Iniciar o dia": some em dia concluído e, p/ usuário, após autorizado (volta no próximo login).
  const btnIni = document.getElementById(turno==="A" ? "iniciarA" : "iniciarB");
  if(btnIni) btnIni.style.display = (concl || (ONLINE && !ehADM() && autorizado)) ? "none" : "";
  // Botão "Imprimir PDF": só p/ o dia recém-concluído cujo PDF/relatório está em cache nesta sessão.
  const btnImp = document.getElementById(turno==="A" ? "imprimirA" : "imprimirB");
  if(btnImp){
    const info = _pdfDia[turno];
    const mostra = !!(info && info.data === data);
    btnImp.style.display = mostra ? "" : "none";
    btnImp.disabled = !mostra;
  }
}

// Atualiza só as células calculadas + total + ação da linha, SEM reconstruir a tabela (preserva o foco).
function refreshLinhaCalc(turno, tr, l){
  const horas = calcHoras(l.horaInicio, l.horaFim);
  const meta  = metaDaLinha(l);   // item 7: meta vigente
  const real  = calcRealizado(l.fardoInicio, l.fardoFinal);
  const calcs = tr.querySelectorAll("td.calc");   // ordem: [horas, meta, realizado]
  if(calcs[0]) calcs[0].innerHTML = horas===null ? `<span class="wait">Aguardando...</span>` : fmtHoras(horas);
  if(calcs[1]) calcs[1].innerHTML = meta===null  ? `<span class="wait">Aguardando...</span>` : fmtNum(Math.round(meta*10)/10);
  if(calcs[2]){
    calcs[2].innerHTML = real===null  ? `<span class="wait">Aguardando...</span>` : fmtNum(real);
    calcs[2].classList.remove("ok","abaixo","erro");      // F26 - cor por hora
    if(real!==null){
      if(motivoRealizadoInvalido(l)) calcs[2].classList.add("erro");
      else { const mf = meta===null ? null : Math.floor(meta); if(mf!==null) calcs[2].classList.add(real>=mf ? "ok" : "abaixo"); }
    }
  }
  let total=0; for(const x of rowsOf(turno)){ const r=calcRealizado(x.fardoInicio,x.fardoFinal); if(r!==null) total+=r; }
  document.getElementById(turno==="A"?"totalA":"totalB").textContent = fmtNum(total);
  if(isEntrada(turno, l)){
    const acaoTd = tr.querySelector("td.col-acao");
    if(acaoTd){
      if(!diaBloqueado(turno,l.data) && linhaCompleta(l)){
        const pend = motivoObrigatorioPendente(l);   // item 9
        acaoTd.innerHTML = pend
          ? `<button class="btn-prox bloq" data-prox="${l.id}" title="${escapeHtml(pend)}">✓ próxima</button>`
          : `<button class="btn-prox" data-prox="${l.id}" title="Concluir esta hora e ir para a próxima">✓ próxima</button>`;
      } else acaoTd.innerHTML = "";
    }
  }
  // destaque visível da linha + aviso inline (em tempo real, conforme digita)
  const bloqL = diaBloqueado(turno, l.data);
  const invalida = !bloqL && !!motivoRealizadoInvalido(l);
  const faltaMot = !bloqL && !isEmptyRow(l) && !invalida && !!motivoObrigatorioPendente(l);
  tr.classList.toggle("linha-invalida", invalida);
  tr.classList.toggle("linha-falta-motivo", faltaMot);
  const ocorWrap = tr.querySelector('td[data-label="Ocorrência"] .ocor-wrap');
  if(ocorWrap){
    let av = ocorWrap.querySelector(".motivo-aviso");
    const msg = faltaMot ? motivoObrigatorioPendente(l) : "";
    if(msg){ if(!av){ av=document.createElement("span"); av.className="motivo-aviso"; ocorWrap.appendChild(av); } av.textContent = "⚠ "+msg; }
    else if(av){ av.remove(); }
  }
  updateConcluirBar(turno);
}

/* ============================================================
   RENDER — resumo diário
   ============================================================ */
function buildResumo(turno){
  const map = new Map();   // data -> {horas, meta, prod, ocor:Set}
  for(const l of rowsOf(turno)){
    if(!l.data) continue;
    if(!map.has(l.data)) map.set(l.data, { horas:0, meta:0, prod:0, ocor:new Set() });
    const g = map.get(l.data);
    const horas = calcHoras(l.horaInicio, l.horaFim);
    const meta  = metaDaLinha(l);   // item 7: meta vigente
    const real  = calcRealizado(l.fardoInicio, l.fardoFinal);
    if(horas!==null) g.horas += horas;
    if(meta !==null) g.meta  += meta;
    if(real !==null) g.prod  += real;
    const ocorTxt = ocorrenciaLabel(l);
    if(ocorTxt) g.ocor.add(ocorTxt);
  }
  return [...map.entries()].sort((a,b)=>a[0]<b[0]?-1:1); // data crescente
}

function renderResumo(turno){
  const data = buildResumo(turno);
  const tbl = document.getElementById(turno==="A" ? "resumoA" : "resumoB");
  let html = `<thead><tr>
      <th>Data</th><th>Turno</th><th>Horas</th><th>Meta</th><th>Produção</th><th>Status</th><th>Ocorrências</th>
    </tr></thead><tbody>`;

  if(data.length===0){
    html += `<tr><td colspan="7" class="empty">Sem lançamentos ainda.</td></tr>`;
  } else {
    let tH=0,tM=0,tP=0;
    for(const [date,g] of data){
      tH+=g.horas; tM+=g.meta; tP+=g.prod;
      const st = statusInfo(g.prod, g.meta);
      const okBadge = isConcluido(turno, date) ? `<span class="badge-ok">✓ concluído</span>` : "";
      html += `<tr>
        <td>${fmtDateBR(date)}${okBadge}</td>
        <td>${turno}</td>
        <td>${fmtHoras(g.horas)}</td>
        <td>${fmtNum(Math.round(g.meta))}</td>
        <td>${fmtNum(g.prod)}</td>
        <td class="status ${st.cls}">${st.short}</td>
        <td class="ocor">${[...g.ocor].map(escapeHtml).join("<br>")}</td>
      </tr>`;
    }
    html += `<tr class="tot-row">
        <td colspan="2">TOTAL</td>
        <td>${fmtHoras(tH)}</td>
        <td>${fmtNum(Math.round(tM))}</td>
        <td>${fmtNum(tP)}</td>
        <td colspan="2"></td>
      </tr>`;
  }
  html += `</tbody>`;
  tbl.innerHTML = html;
}

