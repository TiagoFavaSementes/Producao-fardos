// INICIAR O DIA — libera a edição daquele turno/dia (pede senha no servidor).
async function iniciarDia(turno){
  const data = diaTrabalho(turno);
  if(!data){ toast("Escolha o dia."); return; }
  if(!ONLINE){ // modo local
    diaAutorizado = data;
    const k = chaveDia(turno, data);
    if(!state.iniciados) state.iniciados = [];
    if(!state.iniciados.includes(k)) state.iniciados.push(k);
    save(); renderLanc(turno); toast(`Dia ${fmtDateBR(data)} iniciado (modo local).`); abrirChamadaInicio(turno, data); return;
  }
  if(isConcluido(turno, data)){ toast("Este dia já foi concluído (travado)."); return; }
  const senha = await pedirSenha(`Senha para INICIAR o dia ${fmtDateBR(data)} — Turno ${turno}`);
  if(!senha) return;
  try{
    if(podeAutoUpload()) await flushSync();      // sobe pendências antes de importar do servidor
    const r = await api("iniciarDia", senha, turno, data);
    diaAutorizado = data;                         // autoriza a edição nesta sessão (esconde o botão Iniciar)
    adotarEstado(r.estado);                       // importa o estado mais recente da nuvem
    await refreshTsCarregado(); mostrarBotaoImportar(false);
    toast(`Dia ${fmtDateBR(data)} (Turno ${turno}) iniciado. Edição liberada.`);
    abrirChamadaInicio(turno, data);   // rodada 12: chamada de início (presença) do turno
  }catch(err){ toast("Não foi possível iniciar: " + errMsg(err)); }
}

// CONCLUIR O DIA — online valida senha e trava no servidor; offline usa a fila local.
async function concluirDia(turno){
  const data = diaTrabalho(turno);
  if(!data){ toast("Escolha o dia."); return; }
  const g = computeDaySummary(turno, data);
  if(g.linhas===0){ toast("Não há lançamentos neste dia para concluir."); return; }
  // F2: não deixa concluir com produção fora do normal em alguma linha do dia
  const invalida = rowsOf(turno).some(l => l.data===data && !isEmptyRow(l) && motivoRealizadoInvalido(l));
  if(invalida){ toast("⚠ Há linha(s) com produção fora do normal (negativa ou mais de "+FATOR_OUTLIER+"x a meta). Corrija antes de concluir o dia.", 5000); return; }
  // Item 9: não deixa concluir com baixa produção sem motivo (ou "Outros" sem texto)
  const faltaMotivo = rowsOf(turno).some(l => l.data===data && !isEmptyRow(l) && motivoObrigatorioPendente(l));
  if(faltaMotivo){ toast("⚠ Há hora(s) com baixa produção sem motivo (ou “Outros” sem texto). Informe antes de concluir.", 5000); return; }

  // rodada 12 — CHAMADA DE FIM (reconciliação obrigatória) antes de concluir/gerar o PDF.
  const fim = await abrirChamadaFim(turno, data);
  if(fim === null) return;   // cancelou a chamada de fim -> não conclui

  if(!ONLINE){ concluirDiaLocal(turno); return; }
  const senha = await pedirSenha(`Senha para CONCLUIR o dia ${fmtDateBR(data)} — Turno ${turno}`);
  if(!senha) return;
  try{
    toast("Concluindo o dia e gerando o PDF...", 4000);
    // 2) garante lançamentos + presença na nuvem. Aborta em QUALQUER falha de envio
    //    (sem internet, conflito de versão F9, sessão expirada) — não concluir sobre estado divergente.
    const flushOk = await flushSync();
    if(!flushOk){
      toast("⚠ Dia NÃO concluído: " + (sessaoExpirada ? "sua sessão expirou — faça login de novo"
            : !conexaoOk ? "sem conexão com a nuvem — tente quando a internet voltar"
            : "há um envio mais novo na nuvem — clique em “⤓ Importar último envio” (no topo) e tente de novo") + ".", 6500);
      return;
    }
    // 3) gera o PDF no front
    let pdf = null;
    try{ pdf = await gerarPdfDia(turno, data, g); }catch(e){ console.warn("Falha ao gerar PDF:", e); }
    // 4) sobe o PDF ao Drive ANTES de concluir/imprimir
    let pdfNoDrive = false, aviso = "";
    if(pdf && pdf.base64){
      try{ await api("salvarPDF", SESSAO.token, turno, data, pdf.base64, pdf.nome); pdfNoDrive = true; }
      catch(err){
        if(err && err.rede){ toast("⚠ Dia NÃO concluído: sem conexão para enviar o PDF ao Drive. Tente de novo quando reconectar.", 5500); return; }
        aviso = "o PDF não foi salvo na nuvem (o servidor pode precisar de redeploy) — use Imprimir para o relatório local";
      }
    } else {
      aviso = "não foi possível gerar o PDF (gerador indisponível offline) — use Imprimir para o relatório local";
    }
    // 5) conclui o dia na nuvem (trava + snapshot)
    const r = await api("concluirDia", senha, turno, data);
    diaAutorizado = null;                    // dia fechado: o próximo exige "Iniciar o dia" de novo
    adotarEstado(r.estado);
    ultimoEnvioOk = Date.now(); alteracoesPendentes = false; clearPend(); atualizarStatusSync();
    await refreshTsCarregado(); mostrarBotaoImportar(false);
    // 6) habilita a impressão (PDF gerado ou fallback HTML)
    prepararImpressao(turno, data, pdf, g);
    // 7) toast de resultado
    toast((pdfNoDrive ? `✓ Dia ${fmtDateBR(data)} (Turno ${turno}) concluído e ENVIADO à nuvem; PDF salvo no Drive. `
                      : `✓ Dia ${fmtDateBR(data)} (Turno ${turno}) concluído. `)
          + (aviso ? "⚠ "+aviso+". " : "") + r.resumo.status, 6500);
  }catch(err){
    if(err && err.rede) toast("⚠ Dia NÃO concluído: sem conexão com a nuvem. Tente de novo quando a internet voltar.", 5500);
    else toast("Não foi possível concluir: " + errMsg(err), 5000);
  }
}

function concluirDiaLocal(turno){
  const inp = document.getElementById(turno==="A"?"diaA":"diaB");
  const data = inp.value;
  if(!data){ toast("Escolha o dia a concluir."); return; }
  const g = computeDaySummary(turno, data);
  if(g.linhas===0){ toast("Não há lançamentos neste dia para concluir."); return; }
  const jaConcl = isConcluido(turno, data);
  const msg = `Concluir o dia ${fmtDateBR(data)} — Turno ${turno}?\n\n`+
    `Produção: ${fmtNum(g.prod)} fardos\nMeta: ${fmtNum(Math.round(g.meta))}\nStatus: ${g.status.text}`+
    (jaConcl ? "\n\n(Este dia já foi concluído antes — será atualizado na fila.)" : "");
  if(!confirm(msg)) return;

  const payload = {
    app:"quadro-producao-2026", versao:1,
    turno, data,
    metaPorHora: state.config.metaPorHora,
    horasProd: Math.round(g.horas*100)/100,
    meta: Math.round(g.meta), metaInt: Math.floor(g.meta),
    producao: g.prod,
    status: g.status.text,
    ocorrencias: g.ocor,
    linhas: g.detalhes,
    concluidoEm: new Date().toISOString(),
    enviado: false
  };
  state.outbox = state.outbox.filter(p => !(p.turno===turno && p.data===data)); // substitui dia/turno
  state.outbox.push(payload);
  if(!jaConcl) state.concluidos.push(chaveDia(turno, data));
  save();
  enviarParaNuvem(payload);
  renderLanc(turno); renderResumo("A"); renderResumo("B"); renderConfig();
  atualizarBarraPend();
  prepararImpressao(turno, data, null, g);   // offline: sem PDF no Drive, mas libera o relatório local (Imprimir)
  toast(`Dia ${fmtDateBR(data)} (Turno ${turno}) concluído NESTE APARELHO. ⚠ AINDA NÃO está na nuvem (sem internet) — será enviado quando a conexão voltar e você logar.`, 6000);
}

