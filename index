  }catch(err){ toast("Falha ao importar: " + errMsg(err)); }
}
document.getElementById("btnImportarRecente").addEventListener("click", importarUltimoEnvio);

function msAteProximoCheck(){           // próximo :02 ou :32
  const now = new Date();
  const ms = now.getMinutes()*60000 + now.getSeconds()*1000 + now.getMilliseconds();
  const meia = 30*60000, off = 2*60000;
  let prox = Math.floor(ms/meia)*meia + off;
  if(prox <= ms) prox += meia;
  return prox - ms;
}
function agendarCheckImportar(){
