/* ---------- simulação ---------- */
function randInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }
function isoMinus(days){ const d=new Date(); d.setHours(12,0,0,0); d.setDate(d.getDate()-days); return d.toISOString().slice(0,10); }

function gerarSimulacao(){
  if(ONLINE && !ehADM()){ toast("Apenas ADM/Suporte podem gerar simulação."); return; }
  if(state.lancamentos.some(l=>l.sim) &&
     !confirm("Já existe uma simulação. Gerar de novo vai substituir os dados de simulação atuais. Continuar?")) return;
  // remove simulação anterior e linhas vazias (serão recriadas)
  state.lancamentos = state.lancamentos.filter(l => !l.sim && !isEmptyRow(l));

  const cfgTurnos = { A:{inicio:8,janelas:9}, B:{inicio:19,janelas:9} }; // A 08→17, B 19→04 (cruza meia-noite)
  let contador = 480000;   // contador ÚNICO e contínuo da prensa (A entrega para B, B para A...)
  const cats = state.config.categorias;
  const hhmm = h => String(((h%24)+24)%24).padStart(2,"0")+":00";

  for(let d=6; d>=0; d--){
    const data = isoMinus(d);
    for(const turno of ["A","B"]){
      const {inicio,janelas} = cfgTurnos[turno];
      const paradas = new Set();
      while(paradas.size < randInt(1,2)) paradas.add(randInt(0,janelas-1));
      for(let j=0;j<janelas;j++){
        let realizado, ocor="";
        if(paradas.has(j)){ realizado = randInt(5,12); ocor = cats[randInt(0,cats.length-1)]; }
        else { realizado = randInt(16,20); }   // ~18/h: tende ao real (média ~147/turno, alguns dias acima da meta)
        const ini = contador, fim = ini + realizado;
        contador = fim;
        state.lancamentos.push({ id:uid(), turno, data, sim:true,
          horaInicio:hhmm(inicio+j), horaFim:hhmm(inicio+j+1),
          fardoInicio:String(ini), fardoFinal:String(fim), ocorrencia:ocor });
      }
    }
  }
  simularFuncionarios();   // item 11: popula funcionários de exemplo (local)
  save(); renderAll();
  toast("Simulação de 1 semana gerada (Turno A e B + funcionários de exemplo).");
}
function excluirSimulacao(){
  if(ONLINE && !ehADM()){ toast("Apenas ADM/Suporte."); return; }
  const n = state.lancamentos.filter(l=>l.sim).length;
  if(n===0){ toast("Não há simulação para excluir."); return; }
  if(!confirm(`Excluir ${n} linhas de simulação? Seus lançamentos reais não são afetados.`)) return;
  state.lancamentos = state.lancamentos.filter(l => !l.sim);
  // rodada 12: remove só colaboradores/presença marcados como SIMULAÇÃO (preserva dado real,
  // inclusive a chamada de um dia já iniciado mas ainda sem lançamentos).
  state.funcionarios = (state.funcionarios||[]).filter(c => !c.sim);
  Object.keys(state.presenca||{}).forEach(k => { if(state.presenca[k] && state.presenca[k].sim) delete state.presenca[k]; });
  save(); renderAll();
  if(ONLINE) uploadParaNuvem(false);   // propaga a remoção da simulação ao mestre (ADM/Suporte)
  toast("Simulação excluída.");
}

