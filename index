      if(g.ocor.size) L.push("      Ocorrências: " + [...g.ocor].join("; "));
    }
    L.push("");
  }
  L.push("TOTAL GERAL (A+B): " + fmtNum(totalRealizado("A")+totalRealizado("B")) + " fardos");
  return L.join("\r\n");
}
