<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Quadro de Produção 2026</title>
<style>
  :root{
    --verde:#2e7d32;        --verde-claro:#e8f5e9;  --verde-borda:#a5d6a7;
    --azul:#1565c0;         --azul-claro:#e3f2fd;   --azul-borda:#90caf9;
    --st-verde:#c8e6c9;     --st-amarelo:#fff59d;
    --cinza:#f4f5f7;        --texto:#1f2933;        --borda:#d7dce1;
    --sombra:0 1px 3px rgba(0,0,0,.12),0 1px 2px rgba(0,0,0,.08);
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:"Segoe UI",Roboto,Arial,sans-serif;color:var(--texto);background:var(--cinza);font-size:14px}
  header.app{background:#fff;border-bottom:1px solid var(--borda);padding:10px 16px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:20;box-shadow:var(--sombra)}
  header.app h1{font-size:17px;margin:0;font-weight:700;letter-spacing:.2px}
  header.app .logo{width:30px;height:30px;border-radius:7px;background:linear-gradient(135deg,var(--verde),var(--azul));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800}
  nav.tabs{display:flex;gap:4px;flex-wrap:wrap;margin-left:auto}
  nav.tabs button{border:1px solid transparent;background:transparent;padding:8px 14px;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;color:#52606d}
  nav.tabs button:hover{background:var(--cinza)}
  nav.tabs button.active{color:#fff}
  nav.tabs button.active[data-turno="A"]{background:var(--verde)}
  nav.tabs button.active[data-turno="B"]{background:var(--azul)}
  nav.tabs button.active[data-turno="N"]{background:#37474f}
  main{padding:16px;max-width:1280px;margin:0 auto}
  .view{display:none}
  .view.active{display:block}

  .turno-head{display:flex;align-items:center;gap:14px;flex-wrap:wrap;margin-bottom:14px;padding:14px 18px;border-radius:12px;color:#fff}
  .turno-head.A{background:linear-gradient(135deg,var(--verde),#43a047)}
  .turno-head.B{background:linear-gradient(135deg,var(--azul),#1e88e5)}
  .turno-head h2{margin:0;font-size:18px}
  .turno-head .sub{opacity:.9;font-size:12px}
  .turno-head .total{margin-left:auto;text-align:right}
  .turno-head .total .n{font-size:30px;font-weight:800;line-height:1}
  .turno-head .total .l{font-size:11px;text-transform:uppercase;letter-spacing:.5px;opacity:.9}

  .card{background:#fff;border:1px solid var(--borda);border-radius:12px;box-shadow:var(--sombra);overflow:hidden}
  .table-wrap{overflow-x:auto}
  table.lanc{border-collapse:collapse;width:100%;min-width:980px;font-size:13px}
  table.lanc th{background:#fafbfc;border-bottom:2px solid var(--borda);padding:9px 8px;text-align:left;font-size:11px;text-transform:uppercase;letter-spacing:.3px;color:#52606d;white-space:nowrap}
  table.lanc td{border-bottom:1px solid #eef1f4;padding:4px 6px;vertical-align:middle}
  table.lanc tr:hover td{background:#fcfdff}
  table.lanc input,table.lanc select{width:100%;border:1px solid transparent;background:transparent;padding:6px 6px;border-radius:6px;font-size:13px;font-family:inherit;color:inherit}
  table.lanc input:hover,table.lanc select:hover{border-color:var(--borda)}
  table.lanc input:focus,table.lanc select:focus{outline:none;border-color:var(--azul);background:#fff;box-shadow:0 0 0 2px var(--azul-borda)}
  td.calc{font-variant-numeric:tabular-nums;font-weight:600;color:#3e4c59;white-space:nowrap}
  td.calc .wait{color:#9aa5b1;font-weight:400;font-style:italic}
  td.num input{text-align:right;font-variant-numeric:tabular-nums}
  td.realizado{font-weight:800;color:var(--verde)}
  td.realizado.ok{color:#1b5e20}
  td.realizado.abaixo{color:#8a6d00;background:#fff8e1}
  td.realizado.erro{color:#fff;background:#e12d39;border-radius:6px}
  /* destaque da LINHA inteira quando falta motivo (âmbar) ou produção inválida (vermelho) */
  table.lanc tr.linha-falta-motivo td{background:#fff8e1}
  table.lanc tr.linha-falta-motivo td:first-child{box-shadow:inset 4px 0 0 #f9a825}
  table.lanc tr.linha-invalida td{background:#fdecee}
  table.lanc tr.linha-invalida td:first-child{box-shadow:inset 4px 0 0 #e12d39}
  .motivo-aviso{display:block;font-size:11px;font-weight:700;color:#b06a00;margin-top:3px;line-height:1.25}
  .col-acao{text-align:center;white-space:nowrap;padding-left:6px;padding-right:6px}
  .btn-del{border:none;background:transparent;color:#cbd2d9;cursor:pointer;font-size:16px;line-height:1;padding:4px;border-radius:6px}
  .btn-del:hover{color:#e12d39;background:#fdecee}
  .btn-prox{border:1px solid var(--verde);background:var(--verde-claro);color:#1b5e20;border-radius:6px;padding:4px 10px;cursor:pointer;font-weight:700;font-size:11px;white-space:nowrap}
  .btn-prox:hover{background:#c8e6c9}
  .btn-prox.bloq{opacity:.5;border-style:dashed;cursor:not-allowed}
  .btn-prox.bloq:hover{background:var(--verde-claro)}
  .ocor-wrap{display:flex;flex-direction:column;gap:4px}
  .ocor-wrap .sub-ctl{font-size:12px}

  /* F33 - tela estreita (tablet/celular): tabela de lançamento vira cartões empilhados */
  @media(max-width:820px){
    table.lanc{min-width:0}
    table.lanc thead{display:none}
    table.lanc tbody,table.lanc tr,table.lanc td{display:block;width:100%}
    table.lanc tr{border:1px solid var(--borda);border-radius:10px;margin-bottom:10px;padding:4px 8px;background:#fff}
    table.lanc tr.row-nova{background:#f1f8e9}
    table.lanc td{border-bottom:1px solid #f0f2f5;display:flex;align-items:center;justify-content:space-between;gap:10px;padding:8px 4px}
    table.lanc td:last-child{border-bottom:none}
    table.lanc td::before{content:attr(data-label);font-size:11px;font-weight:700;text-transform:uppercase;color:#52606d;flex:none}
    table.lanc td.col-acao::before{content:""}
    table.lanc input,table.lanc select{width:auto;flex:1;text-align:right;min-height:42px;font-size:15px}
    table.lanc td.calc{font-size:15px}
  }

  .toolbar{display:flex;gap:8px;align-items:center;padding:10px 12px;flex-wrap:wrap}
  button.btn{border:1px solid var(--borda);background:#fff;padding:8px 14px;border-radius:8px;cursor:pointer;font-weight:600;font-size:13px;color:var(--texto)}
  button.btn:hover{background:var(--cinza)}
  button.btn.primary{background:var(--verde);color:#fff;border-color:var(--verde)}
  button.btn.primary.B{background:var(--azul);border-color:var(--azul)}
  button.btn.danger{color:#e12d39;border-color:#f7c5c9}
  button.btn.danger:hover{background:#fdecee}

  /* RESUMO */
  .resumo-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  @media(max-width:900px){.resumo-grid{grid-template-columns:1fr}}
  .resumo-col h3{margin:0 0 10px;font-size:15px;display:flex;align-items:center;gap:8px}
  .dot{width:12px;height:12px;border-radius:50%}
  .dot.A{background:var(--verde)} .dot.B{background:var(--azul)}
  table.resumo{border-collapse:collapse;width:100%;font-size:12.5px}
  table.resumo th{padding:8px 8px;text-align:left;font-size:10.5px;text-transform:uppercase;letter-spacing:.3px;border-bottom:2px solid var(--borda)}
  table.resumo td{padding:7px 8px;border-bottom:1px solid #eef1f4;font-variant-numeric:tabular-nums}
  .resumo-col.A table.resumo th{background:var(--verde-claro);color:#1b5e20}
  .resumo-col.B table.resumo th{background:var(--azul-claro);color:#0d47a1}
  .resumo-col.A table.resumo tbody tr{background:#f4fbf5}
  .resumo-col.B table.resumo tbody tr{background:#f3f9ff}
  td.status{font-weight:800;border-radius:4px;white-space:nowrap;text-align:center}
  td.status.st-acima{background:var(--st-verde);color:#1b5e20}
  td.status.st-abaixo{background:var(--st-amarelo);color:#7a5b00}
  td.ocor{font-size:11px;color:#52606d;max-width:230px;line-height:1.5}
  tr.tot-row td{font-weight:800;border-top:2px solid var(--borda);background:#fff !important}
  .empty{padding:24px;text-align:center;color:#9aa5b1;font-style:italic}

  /* DASHBOARD */
  .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin-bottom:20px}
  .kpi{background:#fff;border:1px solid var(--borda);border-radius:12px;padding:16px;box-shadow:var(--sombra);position:relative;overflow:hidden}
  .kpi::before{content:"";position:absolute;left:0;top:0;bottom:0;width:5px}
  .kpi.A::before{background:var(--verde)} .kpi.B::before{background:var(--azul)} .kpi.G::before{background:linear-gradient(var(--verde),var(--azul))} .kpi.N::before{background:#607d8b}
  .kpi .l{font-size:11px;text-transform:uppercase;letter-spacing:.4px;color:#7b8794;font-weight:600}
  .kpi .v{font-size:30px;font-weight:800;margin-top:6px;font-variant-numeric:tabular-nums}
  .kpi .u{font-size:12px;color:#9aa5b1;font-weight:600}
  .chart-card{background:#fff;border:1px solid var(--borda);border-radius:12px;box-shadow:var(--sombra);padding:18px}
  .chart-card h3{margin:0 0 4px;font-size:16px}
  .chart-card .legend{display:flex;gap:16px;font-size:12px;color:#52606d;margin-bottom:14px}
  .legend .sw{display:inline-block;width:12px;height:12px;border-radius:3px;margin-right:5px;vertical-align:-1px}
  .bar-row{display:grid;grid-template-columns:170px 1fr 70px;align-items:center;gap:10px;margin-bottom:9px}
  .bar-row .name{font-size:12.5px;text-align:right;color:#3e4c59;font-weight:600}
  .bar-track{background:#f0f2f5;border-radius:6px;height:22px;display:flex;overflow:hidden}
  .bar-seg{height:100%;transition:width .6s ease-out}
  .bar-seg.A{background:var(--verde)} .bar-seg.B{background:var(--azul)}
  .bar-row .val{font-weight:800;font-variant-numeric:tabular-nums;font-size:13px}

  /* KPIs em trios A/B/A+B (item 2) */
  .kpi-trios{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:16px;margin-bottom:20px}
  .kpi-trio{display:grid;grid-template-columns:1fr 1fr;grid-auto-rows:1fr;gap:10px}
  .kpi-trio .kpi.A{grid-column:1;grid-row:1}
  .kpi-trio .kpi.B{grid-column:1;grid-row:2}
  .kpi-trio .kpi.G{grid-column:2;grid-row:1 / span 2;display:flex;flex-direction:column;justify-content:center}
  .kpi.kpi-sm{padding:12px 14px}
  .kpi.kpi-sm .v{font-size:22px;margin-top:2px}
  .kpi.kpi-sm .l{font-size:10px}
  .kpi-trio .kpi.G .v{font-size:40px}
  .kpi-trio .kpi.G .l{font-size:12px}

  /* filtro de período (item 1) */
  .dash-filtro{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:16px;background:#fff;border:1px solid var(--borda);border-radius:10px;padding:10px 12px;box-shadow:var(--sombra)}
  .dash-filtro .df-lbl{font-weight:700;color:#52606d;font-size:13px}
  .dash-filtro input[type=date]{padding:7px 9px;border:1px solid var(--borda);border-radius:8px;font-family:inherit;font-size:13px}

  /* ocorrências: A e B em barras próprias, coladas (item 4) */
  .ocor-row{display:grid;grid-template-columns:180px 1fr 84px;align-items:center;gap:10px;margin-bottom:10px}
  .ocor-row .name{font-size:12.5px;text-align:right;color:#3e4c59;font-weight:600}
  .ocor-bars{display:flex;flex-direction:column;gap:2px}
  .ob-track{background:#f0f2f5;border-radius:4px;height:11px;overflow:hidden}
  .ob-track .bar-seg{border-radius:4px}
  .ocor-row .val{font-weight:800;font-variant-numeric:tabular-nums;font-size:13px}

  /* animação de entrada do Dashboard (item 5) */
  @keyframes kpiIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}
  .kpi.anim{animation:kpiIn .45s ease-out both}
  @media(prefers-reduced-motion:reduce){ .kpi.anim{animation:none} .bar-seg{transition:none} }

  /* CONFIG */
  .cfg-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
  @media(max-width:760px){.cfg-grid{grid-template-columns:1fr}}
  .panel{background:#fff;border:1px solid var(--borda);border-radius:12px;box-shadow:var(--sombra);padding:18px}
  .panel h3{margin:0 0 4px;font-size:15px}
  .panel p.hint{margin:0 0 14px;color:#7b8794;font-size:12px}
  .field{display:flex;align-items:center;gap:10px;margin-bottom:10px}
  .field label{font-weight:600;min-width:120px}
  .field input{padding:9px 10px;border:1px solid var(--borda);border-radius:8px;font-size:14px;font-family:inherit;width:120px}
  .cat-list{list-style:none;margin:0;padding:0;max-height:320px;overflow:auto}
  .cat-list li{display:flex;align-items:center;gap:8px;padding:7px 4px;border-bottom:1px solid #eef1f4}
  .cat-list li span{flex:1}
  .cat-list li label.cat-desc{display:flex;align-items:center;gap:3px;flex:none;font-size:9px;font-weight:700;text-transform:uppercase;color:#7b8794;cursor:pointer;white-space:nowrap}
  .cat-add{display:flex;gap:8px;margin-top:12px}
  .cat-add input{flex:1;padding:9px 10px;border:1px solid var(--borda);border-radius:8px;font-size:14px;font-family:inherit}
  .save-flash{font-size:12px;color:var(--verde);font-weight:600;opacity:0;transition:opacity .3s}
  .save-flash.show{opacity:1}

  /* subbar concluir o dia */
  .subbar{display:flex;align-items:center;gap:10px;padding:10px 12px;border-bottom:1px solid var(--borda);flex-wrap:wrap;background:#fafbfc}
  .subbar label{font-weight:600}
  .subbar input[type=date]{padding:7px 9px;border:1px solid var(--borda);border-radius:8px;font-family:inherit;font-size:13px}
  .subbar .spacer{margin-left:auto}
  .subbar .dia-status{font-size:12px;color:#7b8794;font-weight:600}
  button.btn.ghost{background:transparent;border-color:transparent;color:#7b8794}
  button.btn.ghost:hover{background:var(--cinza);color:var(--texto)}
  button.btn.ok{background:#1b8a3a;color:#fff;border-color:#1b8a3a}
  button.btn.ok.B{background:var(--azul);border-color:var(--azul)}
  .badge-ok{display:inline-block;font-size:10px;font-weight:700;color:#1b5e20;background:var(--st-verde);border-radius:999px;padding:1px 7px;margin-left:6px;vertical-align:1px}
  .cfg-note{font-size:12px;color:#52606d;font-weight:600}
  #toast{position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);background:#243b53;color:#fff;padding:12px 18px;border-radius:10px;box-shadow:0 6px 20px rgba(0,0,0,.25);font-size:13px;font-weight:600;opacity:0;pointer-events:none;transition:.25s;z-index:50;max-width:90vw;text-align:center}
  #toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

  /* ----- usuário logado (header) ----- */
  .userbox{display:flex;align-items:center;gap:8px;font-size:12px;color:#52606d}
  .userbox .who{font-weight:700;color:var(--texto)}
  .userbox .perfil{font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.4px;padding:2px 8px;border-radius:999px;background:#eceff1;color:#37474f}
  .userbox .perfil.ADM{background:#fff3e0;color:#e65100}
  .userbox .perfil.SUPORTE{background:#ede7f6;color:#4527a0}
  .userbox .perfil.USUARIO{background:#e8f5e9;color:#1b5e20}
  .userbox .perfil.LOCAL{background:#eceff1;color:#607d8b}
  .userbox button{border:1px solid var(--borda);background:#fff;border-radius:7px;padding:5px 10px;cursor:pointer;font-size:12px;font-weight:600;color:#52606d}
  .userbox button:hover{background:var(--cinza)}

  /* ----- linhas travadas (read-only) ----- */
  table.lanc input:disabled,table.lanc select:disabled{background:transparent;color:#3e4c59;cursor:not-allowed;border-color:transparent !important;box-shadow:none !important;opacity:1}
  table.lanc tr.travada td{background:#fbfcfd}
  .cadeado{color:#9aa5b1;font-size:12px}

  /* ----- overlay de login ----- */
  #login{position:fixed;inset:0;z-index:100;background:linear-gradient(135deg,#1b5e20,#0d47a1);display:flex;align-items:center;justify-content:center;padding:16px}
  #login.hidden{display:none}
  .login-card{background:#fff;border-radius:16px;box-shadow:0 18px 50px rgba(0,0,0,.35);width:100%;max-width:380px;padding:30px 28px;text-align:center}
  .login-card .logo{width:54px;height:54px;border-radius:13px;background:linear-gradient(135deg,var(--verde),var(--azul));color:#fff;font-weight:800;font-size:24px;display:flex;align-items:center;justify-content:center;margin:0 auto 14px}
  .login-card h2{margin:0 0 2px;font-size:19px}
  .login-card p.sub{margin:0 0 20px;color:#7b8794;font-size:12.5px}
  .login-card input[type=password]{width:100%;padding:12px 14px;border:1px solid var(--borda);border-radius:10px;font-size:15px;font-family:inherit;text-align:center;letter-spacing:1px}
  .login-card input[type=password]:focus{outline:none;border-color:var(--azul);box-shadow:0 0 0 3px var(--azul-borda)}
  .login-card button.entrar{width:100%;margin-top:12px;padding:12px;border:none;border-radius:10px;background:var(--verde);color:#fff;font-weight:700;font-size:15px;cursor:pointer}
  .login-card button.entrar:hover{background:#256528}
  .login-erro{color:#e12d39;font-size:12.5px;font-weight:600;margin-top:12px;min-height:16px}
  .login-offline{margin-top:16px;font-size:12px}
  .login-offline a{color:#7b8794;cursor:pointer;text-decoration:underline}
  .login-foot{margin-top:18px;font-size:10.5px;color:#b0b8c1;line-height:1.5}
  .login-tipos{display:flex;flex-direction:column;gap:8px;margin-bottom:10px}
  .tipo-btn{padding:11px;border:1.5px solid var(--borda);border-radius:10px;background:#fff;font-weight:700;font-size:14px;cursor:pointer;color:#52606d}
  .tipo-btn:hover{border-color:var(--azul)}
  .tipo-btn.sel{border-color:var(--verde);background:var(--verde-claro);color:#1b5e20}
  .login-turnos{display:flex;gap:8px;margin-bottom:10px}
  .turno-btn{flex:1;padding:10px;border:1.5px solid var(--borda);border-radius:10px;background:#fff;font-weight:700;cursor:pointer;color:#52606d}
  .turno-btn.sel[data-turno="A"]{border-color:var(--verde);background:var(--verde-claro);color:#1b5e20}
  .turno-btn.sel[data-turno="B"]{border-color:var(--azul);background:var(--azul-claro);color:#0d47a1}

  /* ----- barra/indicador de conexão e sincronização ----- */
  #offlineBar{display:none;background:#c62828;color:#fff;text-align:center;padding:9px 12px;font-size:13px;font-weight:700}
  #offlineBar.amarelo{background:#f9a825;color:#3a2d00}
  body.offline header.app{background:#fff5f5;border-bottom-color:#ffcdd2}
  body.offline header.app .logo{filter:grayscale(.35)}
  .syncind{display:flex;align-items:center;gap:6px;font-size:11px;color:#7b8794;white-space:nowrap}
  .syncind .sdot{width:8px;height:8px;border-radius:50%;background:#43a047;flex:none}
  body.offline .syncind .sdot{background:#c62828}
  .syncind.pend .sdot{background:#f9a825}
  .row-nova td{background:#f1f8e9}
  #btnImportarRecente{border:1px solid #f9a825;background:#fff8e1;color:#8a6d00;border-radius:7px;padding:5px 10px;cursor:pointer;font-size:12px;font-weight:700;box-shadow:0 0 0 3px rgba(249,168,37,.18)}
  #btnImportarRecente:hover{background:#ffecb3}
  #simBadge{display:none;background:#ffe0b2;color:#8a4b00;border:1px solid #ffb74d;border-radius:999px;padding:3px 12px;font-size:11px;font-weight:800;letter-spacing:.5px;white-space:nowrap}

  /* ----- modal de senha (mascarada) p/ iniciar/concluir ----- */
  #senhaModal{position:fixed;inset:0;z-index:110;background:rgba(15,30,50,.45);display:flex;align-items:center;justify-content:center;padding:16px}
  #senhaModal.hidden{display:none}
  .senha-card{background:#fff;border-radius:14px;box-shadow:0 14px 40px rgba(0,0,0,.3);width:100%;max-width:340px;padding:22px}
  .senha-card h3{margin:0 0 14px;font-size:16px}
  .senha-card input{width:100%;padding:11px 12px;border:1px solid var(--borda);border-radius:9px;font-size:15px;font-family:inherit;text-align:center;letter-spacing:2px}
  .senha-card input:focus{outline:none;border-color:var(--azul);box-shadow:0 0 0 3px var(--azul-borda)}
  .senha-btns{display:flex;gap:8px;justify-content:flex-end;margin-top:14px}

  /* ----- modal de CHAMADA (rodada 12): início e fim, centralizado e alinhado ----- */
