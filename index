// edição inline nas tabelas de lançamento
function bindLancTable(turno){
  const tbl = document.getElementById(turno==="A" ? "tblA" : "tblB");
  const aplicarEdicao = (inp)=>{
    const tr = inp.closest("tr"); const id = tr.dataset.id;
    const l = state.lancamentos.find(x=>x.id===id); if(!l) return;
    const field = inp.dataset.f;
    // Preenchimentos automáticos na linha em edição:
    // FARDO INÍCIO = último fardo final lançado; HORA INÍCIO = última hora fim do turno.
    if(field!=="fardoInicio" && (l.fardoInicio===""||l.fardoInicio==null)){
      const sug = proximoFardoInicio(l.id);
      if(sug!==null){ l.fardoInicio = String(sug); const fi=tr.querySelector('[data-f="fardoInicio"]'); if(fi && fi.value==="") fi.value=l.fardoInicio; }
    }
    if(field!=="horaInicio" && !l.horaInicio){
      const sh = proximaHoraInicio(turno, l.id);
      if(sh){ l.horaInicio = sh; const hi=tr.querySelector('[data-f="horaInicio"]'); if(hi && !hi.value) hi.value=sh; }
    }
    if(field!=="data" && !l.dataReal){
      const sd = proximaDataReal(turno, l.id);   // DATA real = puxa a anterior, +1 dia após meia-noite
      if(sd){ l.dataReal = sd; const di=tr.querySelector('[data-f="data"]'); if(di && !di.value) di.value=sd; }
    }
    // Fardos: só inteiros, nunca negativos.
    let valor = inp.value;
    if(field==="fardoInicio" || field==="fardoFinal"){
      if(valor!=="" && !isNaN(Number(valor))){
        const n = Math.max(0, Math.floor(Number(valor)));
        if(String(n)!==valor){ valor = String(n); inp.value = valor; }
      }
    }
    if(field==="descarocador"){ l.descarocador = Number(valor)||7; }   // item 8: guarda como número
    else if(field==="data"){ l.dataReal = valor; }   // coluna Data = SÓ data real (calendário); NÃO mexe no dia de produção (l.data)
    else { l[field] = valor; }
    // Item 8/9: ao escolher a ocorrência, ajusta campos dependentes
    if(field==="ocorrencia"){
      if(envolveDescarocador(l.ocorrencia)){ if(!l.descarocador) l.descarocador = 7; }   // default 7 (backup)
      else { delete l.descarocador; }
      if(l.ocorrencia!=="OUTROS") delete l.outrosTexto;
    }
    // USUÁRIO online: amarra a linha nova ao dia de trabalho autorizado
    // DIA DE PRODUÇÃO (l.data) — fixado UMA vez; nunca pode ficar vazio numa linha real (toda agregação usa l.data).
    // USUÁRIO: o dia autorizado. ADM/offline: o dia da barra; senão o dia de produção calculado (corte 06:00); senão a data real.
    if(!l.data){ l.data = (ONLINE && !ehADM()) ? diaTrabalho(turno) : (diaTrabalho(turno) || diaProducaoDe(l) || l.dataReal || ""); }
    if(ONLINE && logado()) addPend(id);   // F10: esta linha ainda não está na nuvem
    save();
    // Mudar a ocorrência revela/oculta o seletor de descaroçador e o campo "Outros" -> re-render.
    if(field==="ocorrencia"){ renderLanc(turno); return; }
    refreshLinhaCalc(turno, tr, l);   // in-place: não reconstrói a tabela -> preserva o foco
  };
  // Data e hora só são gravadas ao TERMINAR a edição (change) — evita salvar valores
  // parciais (ex.: ano "0002") enquanto digita. Números/ocorrência atualizam em tempo real.
  tbl.addEventListener("input", e=>{
    const inp = e.target.closest("[data-f]"); if(!inp) return;
    if(inp.type==="date" || inp.type==="time") return;
    aplicarEdicao(inp);
  });
  tbl.addEventListener("change", e=>{
    const inp = e.target.closest("[data-f]"); if(!inp) return;
    aplicarEdicao(inp);
  });
  // ações: "✓ próxima hora" e excluir linha
  tbl.addEventListener("click", e=>{
    const prox = e.target.closest("[data-prox]");
    if(prox){
      const l = state.lancamentos.find(x=>x.id===prox.dataset.prox);
      const motivo = l ? motivoRealizadoInvalido(l) : null;   // F2: não deixa avançar com produção fora do normal
      if(motivo){ toast("⚠ " + motivo, 5000); return; }
      const inc = l ? motivoLinhaIncompleta(l) : "Linha não encontrada.";   // data/hora fora do padrão ou fardos faltando
      if(inc){ toast("⚠ " + inc, 4500); return; }
      const pend = l ? motivoObrigatorioPendente(l) : null;   // item 9: baixa produção / Outros sem texto
      if(pend){ toast("⚠ " + pend, 4800); return; }
      if(!l || !linhaCompleta(l)){ toast("Preencha a linha corretamente antes de passar para a próxima hora."); return; }
      ensureTrailingBlank(turno);          // cria a próxima linha em branco
      save(); renderLanc(turno);           // re-render: a nova linha aparece no topo
      const novo = document.querySelector(`#tbl${turno} tbody tr input:not([disabled])`);
      if(novo) novo.focus();
      return;
    }
    const del = e.target.closest("[data-del]");
    if(del){
      const id = del.dataset.del;
      const l = state.lancamentos.find(x=>x.id===id);
      if(l && !podeExcluirLinha(turno, l)){
        toast("Você só pode excluir as 2 ÚLTIMAS linhas lançadas. As anteriores ficam travadas (chame o ADM se precisar corrigir).", 4500);
        return;
      }
      state.lancamentos = state.lancamentos.filter(x=>x.id!==id);
      save(); renderLanc(turno);
    }
  });
}
