<script>
/* ============================================================
   QUADRO DE PRODUÇÃO 2026  —  app de página única (offline)
   ============================================================ */
const STORE_KEY = "quadro_producao_2026";

/* ============================================================
   BACKEND (Google Apps Script) — conexão por fetch
   ------------------------------------------------------------
   OBS DE SEGURANÇA: a URL abaixo está só "ofuscada" em base64 para
   não aparecer como texto cru. ISSO NÃO É CRIPTOGRAFIA — qualquer um
   vê o endereço no DevTools. A proteção real é a senha validada no
   servidor + trava anti-tentativas. Não coloque segredos no frontend.
   ============================================================ */
const _u = "aHR0cHM6Ly9zY3JpcHQuZ29vZ2xlLmNvbS9tYWNyb3Mvcy9BS2Z5Y2J6NmhqYVgwSWdGdmtvNWUwdmRIcUsycDgxY2ozSFFFbXo0N01pZ1VtQmJoSmo3dTBjVmhGZUNNQzJFdV9nRXZxY1ktZy9leGVj";
const BACKEND_URL = atob(_u);

// Chama uma função do backend. Retorna o valor de retorno da função (já desembrulhado).
// Erros de REDE (sem internet / servidor inacessível) saem com err.rede = true;
// erros do SERVIDOR (senha errada, sessão expirada...) saem como Error normal.
async function api(fn){
  const args = Array.prototype.slice.call(arguments, 1);
  let resp, data;
  try{
    resp = await fetch(BACKEND_URL, {
      method: "POST",
      headers: { "Content-Type": "text/plain;charset=utf-8" }, // evita preflight de CORS
      body: JSON.stringify({ fn: fn, args: args }),
      redirect: "follow"
    });
    data = await resp.json();
  }catch(e){
    const err = new Error("Sem conexão com o servidor.");
    err.rede = true;
    throw err;
  }
  if(!data.ok) throw new Error(data.erro || "Erro no servidor.");
  return data.resultado;
}
function errMsg(e){ return (e && e.message) ? e.message : String(e); }
function ehErroSessao(e){ return /sess[aã]o (expirada|ausente)/i.test(errMsg(e)); }

// Sessão / modo de operação
let ONLINE = false;                                   // true após login no servidor
let SESSAO = { token:null, perfil:null, nome:null, turno:null, permissoes:{} };
function logado(){ return !!SESSAO.token; }
function ehADM(){ return SESSAO.perfil==="ADM" || SESSAO.perfil==="SUPORTE"; }
function ehSuporte(){ return SESSAO.perfil==="SUPORTE"; }
function podeConfig(){ return !ONLINE || ehADM(); }   // offline = liberado p/ teste

// Categorias reais usadas na planilha (PRODUÇÃO A!M9:M40), limpas e sem duplicatas.
const CATEGORIAS_PADRAO = [
  "ABASTECIMENTO (PIRANHA/PRENSA)",
  "ACIDENTE DE TRABALHO",
  "AJUSTES INICIAIS/OPERACIONAIS",
  "BUCHA - BATEDOR",
  "BUCHA - DESCAROÇADOR",
  "BUCHA - FIBRILHA",
  "BUCHA - GERAL",
  "BUCHA - HL/CICLONE",
  "BUCHA - LIMPA PLUMA/CONDENSADOR",
  "BUCHA - PIRANHA",
  "BUCHA - PRENSA/CALCADOR",
  "BUCHA - ROSCA/ROSCÃO",
  "CONCERTAR CORRENTE DA ENGRENAGEM",
  "HORÁRIO DE ALMOÇO/JANTAR",
  "FOGO - BATEDOR",
  "FOGO - DESCAROÇADOR",
  "FOGO - GERAL",
  "LIMPEZA",
  "MANUTENÇÃO - BALANÇA",
  "MANUTENÇÃO - BATEDOR",
  "MANUTENÇÃO - ELÉTRICA GERAL",
  "MANUTENÇÃO - LIMPA PLUMA",
  "MANUTENÇÃO - PIRANHA/ESTEIRA",
  "MANUTENÇÃO - PRENSA",
  "MANUTENÇÃO - ROSCAS",
  "PARADA - DESCANSO",
  "PROBLEMA NO AR DO CAROÇO",
  "PROBLEMA NO MOTOR",
  "PROBLEMA NO MOTOR DO HL",
  "TROCA DAS CORREIAS DO MOTOR DA CASCA",
  "TROCA DO MANCAU",
  "OUTROS"
];

let state = load();

function load(){
  try{
    const raw = localStorage.getItem(STORE_KEY);
    if(raw){
      const s = JSON.parse(raw);
      s.config = s.config || {};
      if(typeof s.config.metaPorHora !== "number") s.config.metaPorHora = 17;
      if(typeof s.config.metaAjuste !== "number") s.config.metaAjuste = 10;
      if(typeof s.config.safra !== "string") s.config.safra = "2025/26";
      if(!Array.isArray(s.config.descarocadorCats)) s.config.descarocadorCats = ["BUCHA - DESCAROÇADOR","FOGO - DESCAROÇADOR"];
      if(!Array.isArray(s.config.categorias)) s.config.categorias = CATEGORIAS_PADRAO.slice();
      if(!Array.isArray(s.lancamentos)) s.lancamentos = [];
      if(!Array.isArray(s.concluidos)) s.concluidos = [];   // chaves "turno|data" concluídas
      if(!Array.isArray(s.iniciados)) s.iniciados = [];     // chaves "turno|data" liberadas p/ edição
      if(!Array.isArray(s.outbox)) s.outbox = [];           // fila de dias (modo offline)
      if(!Array.isArray(s.funcionarios)) s.funcionarios = [];   // rodada 12: roster (nuvem)
      normPresenca(s);                                          // rodada 12: presença "T|data" -> {inicio,fim,ajustes}
      return migrarDesanso(s);
    }
  }catch(e){ console.warn("Falha ao ler dados:", e); }
  return { config:{ metaPorHora:17, metaAjuste:10, safra:"2025/26", descarocadorCats:["BUCHA - DESCAROÇADOR","FOGO - DESCAROÇADOR"], categorias:CATEGORIAS_PADRAO.slice() }, lancamentos:[], concluidos:[], iniciados:[], outbox:[], funcionarios:[], presenca:{} };
}

// rodada 12 — normaliza state.presenca para o formato { "T|data": {inicio:[],fim:[],ajustes:{}} }.
// Aceita e migra o formato antigo (array simples de ids = quem estava presente) -> vira o "inicio".
function normPresenca(s){
  if(!s.presenca || typeof s.presenca!=="object" || Array.isArray(s.presenca)) s.presenca = {};
  for(const k in s.presenca){
    const p = s.presenca[k];
    if(Array.isArray(p)){ s.presenca[k] = { inicio:p.slice(), fim:[], ajustes:{} }; }
    else if(p && typeof p==="object"){
      p.inicio  = Array.isArray(p.inicio) ? p.inicio : [];
      p.fim     = Array.isArray(p.fim)    ? p.fim    : [];
      p.ajustes = (p.ajustes && typeof p.ajustes==="object" && !Array.isArray(p.ajustes)) ? p.ajustes : {};
    } else { s.presenca[k] = { inicio:[], fim:[], ajustes:{} }; }
  }
  return s;
}
// rodada 12 — ids creditados numa chave de presença: união de quem entrou (início) e quem saiu (fim).
function presCreditados(p){
  if(!p) return [];
  if(Array.isArray(p)) return p.slice();                       // tolera formato antigo
  const set = new Set([...(p.inicio||[]), ...(p.fim||[])]);
  return [...set];
}

// Migração de grafia antiga: "DESANSO" -> almoço/jantar; "...CARAÇO" -> "...CAROÇO".
function migrarDesanso(s){
  const mapa = c => c==="DESANSO" ? "HORÁRIO DE ALMOÇO/JANTAR"
                  : c==="PROBLEMA NO AR DO CARAÇO" ? "PROBLEMA NO AR DO CAROÇO"
                  : c;
  if(s && s.config && Array.isArray(s.config.categorias))
    s.config.categorias = s.config.categorias.map(mapa);
  if(s && Array.isArray(s.lancamentos))
    s.lancamentos.forEach(l => { if(l && l.ocorrencia) l.ocorrencia = mapa(l.ocorrencia); });
  return s;
}
// Normaliza um estado vindo do servidor para o formato local.
function normalizarEstadoLocal(s){
  s = s || {};
  s.config = s.config || {};
  if(typeof s.config.metaPorHora !== "number") s.config.metaPorHora = 17;
  if(typeof s.config.metaAjuste !== "number") s.config.metaAjuste = 10;
  if(typeof s.config.safra !== "string") s.config.safra = "2025/26";
  if(!Array.isArray(s.config.descarocadorCats)) s.config.descarocadorCats = ["BUCHA - DESCAROÇADOR","FOGO - DESCAROÇADOR"];
  if(!Array.isArray(s.config.categorias)) s.config.categorias = CATEGORIAS_PADRAO.slice();
  if(!Array.isArray(s.lancamentos)) s.lancamentos = [];
  if(!Array.isArray(s.concluidos)) s.concluidos = [];
  if(!Array.isArray(s.iniciados)) s.iniciados = [];
  if(!Array.isArray(s.outbox)) s.outbox = [];
  if(!Array.isArray(s.funcionarios)) s.funcionarios = [];   // rodada 12: roster vindo da nuvem
  normPresenca(s);                                          // rodada 12: presença no formato novo
  return migrarDesanso(s);
}
// Adota um estado do servidor e redesenha tudo.
function adotarEstado(est){
  state = normalizarEstadoLocal(est);
  localStorage.setItem(STORE_KEY, JSON.stringify(state));
  renderAll();
}

/* ============================================================
   SINCRONIZAÇÃO COM A NUVEM
   - usuário de inclusão (Produção A/B): upload automático a cada 30 min + ao concluir
   - ADM/Suporte: upload só manual (botão "Sincronizar agora")
   - tudo fica no cache local; quando offline, o app muda de cor
   ============================================================ */
const INTERVALO_SYNC_MS = 30*60*1000;     // 30 minutos (tempo real)
let conexaoOk = navigator.onLine;
let ultimoEnvioOk = null;                 // timestamp do último upload bem-sucedido
let alteracoesPendentes = false;          // há mudanças locais ainda não enviadas?
let enviando = false;
let sessaoExpirada = false;               // sessão caiu no servidor (não é falta de internet)

// save(): persiste no cache local com debounce (não trava a digitação) e marca pendência.
let saveT = null;
function gravarCacheAgora(){ clearTimeout(saveT); saveT = null; localStorage.setItem(STORE_KEY, JSON.stringify(state)); }
function save(){
  clearTimeout(saveT);
  saveT = setTimeout(gravarCacheAgora, 300);
  if(ONLINE && logado()) alteracoesPendentes = true;
  atualizarStatusSync();
}
function podeAutoUpload(){ return ONLINE && logado() && SESSAO.perfil==="USUARIO"; }

/* ============================================================
   F10 - PENDÊNCIAS DE ENVIO (persistidas, sobrevivem ao recarregar)
   Conta lançamentos editados que ainda NÃO foram confirmados na nuvem,
   + dias concluídos offline na fila (outbox). Mostra na barra vermelha/âmbar.
   ============================================================ */
const PEND_KEY = "quadro_pend_2026";
function lerPend(){ try{ const a = JSON.parse(localStorage.getItem(PEND_KEY)); return Array.isArray(a) ? a : []; }catch(e){ return []; } }
function addPend(id){ if(!id) return; const a = lerPend(); if(a.indexOf(id)<0){ a.push(id); localStorage.setItem(PEND_KEY, JSON.stringify(a)); } }
function clearPend(){ try{ localStorage.removeItem(PEND_KEY); }catch(e){} }
function countPend(){ try{ return lerPend().length + ((state && Array.isArray(state.outbox)) ? state.outbox.length : 0); }catch(e){ return 0; } }

// Barra superior: vermelha quando offline, âmbar quando online com pendências, escondida quando tudo enviado.
function atualizarBarraPend(){
  const bar = document.getElementById("offlineBar");
  const txt = document.getElementById("offlineBarTxt");
  if(!bar || !txt) return;
  const n = countPend();
  if(!conexaoOk){
    bar.classList.remove("amarelo");
    bar.style.display = "block";
    txt.textContent = "⚠ Sem internet — trabalhando offline. " +
      (n>0 ? (n + " lançamento(s)/dia(s) ainda NÃO enviados — serão enviados quando a internet voltar.")
           : "Seus dados ficam salvos e sobem assim que a conexão voltar.");
  } else if(n>0 && (sessaoExpirada || !ONLINE || SESSAO.perfil!=="USUARIO" || alteracoesPendentes)){
    bar.classList.add("amarelo");
    bar.style.display = "block";
    txt.textContent = (sessaoExpirada ? "Sessão expirou — faça login de novo. " : "") +
      n + " lançamento(s)/dia(s) aguardando envio à nuvem.";
  } else if(n>0){
    bar.classList.add("amarelo");
    bar.style.display = "block";
    txt.textContent = n + " lançamento(s)/dia(s) aguardando envio à nuvem.";
  } else {
    bar.style.display = "none";
  }
}

// Envia o estado atual para a nuvem. silencioso=true não mostra toast.
async function uploadParaNuvem(silencioso){
  if(!ONLINE || !logado() || enviando) return false;
  enviando = true; atualizarStatusSync();
  try{
    const r = await api("salvarEstado", SESSAO.token, state, tsCarregado);  // F9: manda a versão que carreguei
    state = normalizarEstadoLocal(r.estado);
    localStorage.setItem(STORE_KEY, JSON.stringify(state));
    ultimoEnvioOk = Date.now();
    alteracoesPendentes = false;
    sessaoExpirada = false;
    clearPend();                            // F10: tudo confirmado na nuvem
    tsCarregado = r.ts || tsCarregado;
    mostrarBotaoImportar(false);
    marcarConexao(true);
    const foco = document.activeElement && document.activeElement.closest && document.activeElement.closest("table.lanc");
    if(!foco) renderAll();
    if(!silencioso) toast("Enviado para a nuvem com sucesso ✓");
    return true;
  }catch(err){
    if(err && err.rede){
      marcarConexao(false);                 // problema de internet de verdade
      if(!silencioso) toast("Sem conexão — não foi possível sincronizar agora.");
    } else if(/CONFLITO_NUVEM/.test(errMsg(err))){
      // F9: a nuvem tem um envio mais novo. NÃO sobrescreve — manda importar antes.
      marcarConexao(true);
      mostrarBotaoImportar(true);
      if(!silencioso) toast("Há um envio MAIS NOVO na nuvem. Clique em “⤓ Importar último envio” (no topo) antes de sincronizar.", 5500);
    } else if(ehErroSessao(err)){
      sessaoExpirada = true;                // sessão caiu: NÃO é falta de internet
      marcarConexao(true);
      if(!silencioso) toast("Sua sessão expirou — clique em Sair e faça login novamente.");
    } else {
      marcarConexao(true);                  // servidor respondeu (outro erro)
      if(!silencioso) toast("Não foi possível sincronizar: " + errMsg(err));
    }
    return false;
  }finally{ enviando = false; atualizarStatusSync(); }
}
// Garante que as alterações locais foram enviadas (usado antes de concluir o dia).
// Espera um envio em andamento terminar antes de tentar — assim "ocupado" não vira falso "falhou".
async function flushSync(){
  for(let i=0; i<40 && enviando; i++){ await new Promise(r=>setTimeout(r,150)); }   // até ~6s
  return await uploadParaNuvem(true);
}

function horaCurta(ts){ const d=new Date(ts); return String(d.getHours()).padStart(2,"0")+":"+String(d.getMinutes()).padStart(2,"0"); }
function atualizarStatusSync(){
  const ind = document.getElementById("syncInd"); if(!ind) return;
  const txt = document.getElementById("syncTxt");
  ind.classList.toggle("pend", alteracoesPendentes && conexaoOk);
  let s;
  if(!conexaoOk) s = "sem internet";
  else if(sessaoExpirada) s = "sessão expirada — refaça o login";
  else if(enviando) s = "enviando...";
  else if(ultimoEnvioOk) s = "nuvem " + horaCurta(ultimoEnvioOk) + (alteracoesPendentes ? " · pendente" : "");
  else s = alteracoesPendentes ? "não enviado" : "—";
  if(txt) txt.textContent = s;
  const si = document.getElementById("syncInfo");
  if(si) si.textContent = ultimoEnvioOk ? ("Último envio: " + new Date(ultimoEnvioOk).toLocaleString("pt-BR")) : "Nenhum envio nesta sessão.";
  atualizarBarraPend();   // F10: mantém a barra superior em dia
}

/* conexão / offline */
function marcarConexao(ok){
  conexaoOk = ok;
  document.body.classList.toggle("offline", !ok);
  atualizarStatusSync();
}
window.addEventListener("online",  ()=>{ marcarConexao(true);  if(podeAutoUpload() && alteracoesPendentes) tentarUploadComRetry(); });
window.addEventListener("offline", ()=> marcarConexao(false));
// Ao fechar/atualizar a página: grava o cache na hora e, se houver dados não enviados, avisa.
window.addEventListener("beforeunload", e=>{
  if(saveT) gravarCacheAgora();
  if(ONLINE && logado() && alteracoesPendentes){ e.preventDefault(); e.returnValue = ""; }
});

/* Upload automático nas MARCAS DO RELÓGIO (:00 e :30). Se falhar, tenta a cada 2 min até subir.
   Silencioso — não mostra nada na tela. Só o usuário de inclusão (Produção A/B). */
function msAteProximaMeiaHora(){
  const now = new Date();
  const ms = now.getMinutes()*60000 + now.getSeconds()*1000 + now.getMilliseconds();
  const meia = 30*60000;
  return meia - (ms % meia);
}
let retryTimer = null;
async function tentarUploadComRetry(){
  if(!podeAutoUpload() || !alteracoesPendentes) return;
  const ok = await uploadParaNuvem(true);                 // silencioso
  clearTimeout(retryTimer);
  if(!ok) retryTimer = setTimeout(tentarUploadComRetry, 2*60000);   // tenta de novo em 2 min
}
function agendarUploadRelogio(){
  setTimeout(()=>{
    if(podeAutoUpload() && alteracoesPendentes) tentarUploadComRetry();
    agendarUploadRelogio();                                // reagenda para a próxima marca (:00/:30)
  }, msAteProximaMeiaHora());
}
agendarUploadRelogio();

/* ============================================================
   "IMPORTAR ÚLTIMO ENVIO" (ADM / Suporte)
   Nos minutos :02 e :32 (2 min após o upload do usuário), verifica se há um
   envio MAIS RECENTE na nuvem e, se houver, mostra o botão para atualizar.
   ============================================================ */
let tsCarregado = 0;   // hora (do servidor) da versão que o cliente tem agora
async function refreshTsCarregado(){
  if(!ONLINE || !logado()) return;
  try{ const s = await api("statusNuvem", SESSAO.token); if(s && s.ts) tsCarregado = s.ts; }catch(e){}
}
function mostrarBotaoImportar(mostrar){
