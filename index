// Consolida um dia (turno+data): somas, status, ocorrências e detalhes das linhas.
function computeDaySummary(turno, data){
  const det = [];
  let horas=0, meta=0, prod=0; const ocor=new Set();
  for(const l of rowsOf(turno)){
    if(l.data!==data) continue;
    const h=calcHoras(l.horaInicio,l.horaFim);
    const m=metaDaLinha(l);   // item 7: meta vigente da janela
    const r=calcRealizado(l.fardoInicio,l.fardoFinal);
    if(h!==null) horas+=h;
    if(m!==null) meta+=m;
    if(r!==null) prod+=r;
    const ocorTxt = ocorrenciaLabel(l);
    if(ocorTxt) ocor.add(ocorTxt);
    det.push({
      horaInicio:l.horaInicio, horaFim:l.horaFim,
      horasProd: h===null?null:Math.round(h*100)/100,
      fardoInicio: l.fardoInicio===""?null:Number(l.fardoInicio),
      fardoFinal:  l.fardoFinal===""?null:Number(l.fardoFinal),
      meta: m===null?null:Math.round(m*100)/100,
      realizado: r,
      ocorrencia: ocorTxt
    });
  }
  return { linhas:det.length, horas, meta, prod, ocor:[...ocor], status:statusInfo(prod,meta), detalhes:det };
}

/* ============================================================
   RODADA 12 — PDF DIÁRIO (gera no front -> sobe ao Drive -> libera impressão)
   jsPDF + autotable carregados sob demanda (CDN). Fallback: relatório HTML + print.
   ============================================================ */
let _jsPdfPromise = null;
function carregarScript(src){
  return new Promise((res,rej)=>{ const s=document.createElement("script"); s.src=src; s.async=true; s.onload=res; s.onerror=()=>rej(new Error("Falha ao carregar "+src)); document.head.appendChild(s); });
}
function carregarJsPDF(){
  if(window.jspdf && window.jspdf.jsPDF) return Promise.resolve(true);
  if(_jsPdfPromise) return _jsPdfPromise;
  _jsPdfPromise = (async ()=>{
    await carregarScript("https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js");
    await carregarScript("https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js");
    if(!(window.jspdf && window.jspdf.jsPDF)) throw new Error("jsPDF indisponível");
    return true;
  })().catch(e=>{ _jsPdfPromise=null; throw e; });
  return _jsPdfPromise;
}
// Gera o PDF do dia (P&B, A4). Retorna { blob, base64, nome }. Lança se o gerador não carregar.
async function gerarPdfDia(turno, data, g){
  await carregarJsPDF();
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ unit:"pt", format:"a4" });
  const W = doc.internal.pageSize.getWidth(), PH = doc.internal.pageSize.getHeight();
  const safra = state.config.safra || "";
  const agora = new Date();
  const hh = String(agora.getHours()).padStart(2,"0"), mm = String(agora.getMinutes()).padStart(2,"0");
  // Cabeçalho
  doc.setFont("helvetica","bold"); doc.setFontSize(15); doc.setTextColor(20);
  doc.text("Produção Diária de Algodão", W/2, 44, {align:"center"});
  doc.setFont("helvetica","normal"); doc.setFontSize(10); doc.setTextColor(80);
  doc.text(`Safra ${safra}   ·   Turno ${turno}   ·   ${fmtDateBR(data)}`, W/2, 62, {align:"center"});
  doc.text(`Gerado em ${fmtDateBR(isoLocal(agora))} ${hh}:${mm}`, W/2, 76, {align:"center"});
  doc.setDrawColor(170); doc.line(40, 86, W-40, 86);
  // KPIs
  const st = statusInfo(g.prod, g.meta);
  doc.setFontSize(10); doc.setTextColor(30);
  const kpis = [["Produção total", fmtNum(g.prod)+" fardos"],["Meta do dia", fmtNum(Math.round(g.meta))],
                ["Horas trabalhadas", fmtHoras(g.horas)],["Status", st.text]];
  let ky = 104;
  kpis.forEach(([k,v])=>{ doc.setFont("helvetica","bold"); doc.text(k+":", 44, ky); doc.setFont("helvetica","normal"); doc.text(String(v), 168, ky); ky+=16; });
  // Tabela do dia (espelha computeDaySummary)
  const body = g.detalhes.map(d=>[
    d.horaInicio||"", d.horaFim||"",
    d.horasProd==null?"":(fmtNum(Math.round(d.horasProd*100)/100)+"h"),
    d.fardoInicio==null?"":String(d.fardoInicio), d.fardoFinal==null?"":String(d.fardoFinal),
    d.meta==null?"":fmtNum(Math.floor(d.meta)),
    d.realizado==null?"":fmtNum(d.realizado),
    d.ocorrencia||""
  ]);
  body.push(["TOTAL","",fmtHoras(g.horas),"","",fmtNum(Math.round(g.meta)),fmtNum(g.prod),""]);
  doc.autoTable({
    startY: ky+8,
    head: [["Início","Fim","Horas","Fardo iní.","Fardo fin.","Meta","Realiz.","Ocorrência"]],
    body,
    styles:{ fontSize:8.5, cellPadding:3, textColor:30, lineColor:200, lineWidth:0.3 },
    headStyles:{ fillColor:[235,235,235], textColor:20, fontStyle:"bold" },
    columnStyles:{ 7:{ cellWidth:150 } },
    theme:"grid",
    didParseCell:(h)=>{ if(h.section==="body" && h.row.index===body.length-1){ h.cell.styles.fontStyle="bold"; h.cell.styles.fillColor=[245,245,245]; } }
  });
  // Prestadores presentes
  const prest = calcPrestadoresDoDia(turno, data);
  let y2 = doc.lastAutoTable.finalY + 20;
  doc.setFont("helvetica","bold"); doc.setFontSize(11); doc.setTextColor(20);
  doc.text("Prestadores presentes", 44, y2);
  if(prest.length){
    doc.autoTable({
      startY: y2+6,
      head: [["Colaborador","Horas","Fardos atribuídos"]],
      body: prest.map(p=>[p.nome, fmtHoras(p.horas), fmtNum(Math.round(p.fardos))]),
      styles:{ fontSize:9, cellPadding:3, textColor:30, lineColor:200, lineWidth:0.3 },
      headStyles:{ fillColor:[235,235,235], textColor:20, fontStyle:"bold" },
      theme:"grid"
    });
    y2 = doc.lastAutoTable.finalY;
  } else {
    doc.setFont("helvetica","normal"); doc.setFontSize(9); doc.setTextColor(110);
    doc.text("Nenhum prestador registrado na chamada.", 44, y2+16); y2 += 16;
  }
  // Assinaturas
  let sy = y2 + 64;
  if(sy > PH-70){ doc.addPage(); sy = 120; }
  const colW = (W-80)/2;
  doc.setDrawColor(60);
  doc.line(60, sy, 60+colW-30, sy);
  doc.line(60+colW+10, sy, 60+colW*2-20, sy);
  doc.setFont("helvetica","normal"); doc.setFontSize(9); doc.setTextColor(40);
  doc.text("Gestor da Produção", 60, sy+14);
  doc.text("Gestor Administrativo", 60+colW+10, sy+14);
  doc.text("Data: ___/___/______", 60, sy+34);
  const nome = `Produção Turno ${turno} - ${data} - ${hh}h${mm}m.pdf`;
  const blob = doc.output("blob");
  const base64 = (doc.output("datauristring").split(",")[1]) || "";
  return { blob, base64, nome };
}

